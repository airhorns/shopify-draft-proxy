# Proxy runtime
SHOPIFY_ADMIN_ORIGIN=https://your-store.myshopify.com
SHOPIFY_DRAFT_PROXY_READ_MODE=live-hybrid
SHOPIFY_DRAFT_PROXY_SNAPSHOT_PATH=
PORT=3000

# Real Shopify conformance target
SHOPIFY_CONFORMANCE_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CONFORMANCE_ADMIN_ORIGIN=https://your-store.myshopify.com
SHOPIFY_CONFORMANCE_API_VERSION=2026-04
SHOPIFY_CONFORMANCE_APP_HANDLE=
SHOPIFY_CONFORMANCE_APP_ID=
SHOPIFY_CONFORMANCE_APP_API_KEY=
# Shopify conformance auth now lives outside the repo at:
#   ~/.shopify-draft-proxy/conformance-admin-auth.json
# Generate a fresh grant link with:
#   corepack pnpm conformance:auth-link

# Storefront API conformance target (optional — used for storefront parity recordings)
# The storefront access token is stored outside the repo at:
#   ~/.shopify-draft-proxy/conformance-storefront-auth.json
# Grant a new storefront token from the active Admin API credential with:
#   corepack pnpm conformance:grant-storefront-token
# The storefront API endpoint is https://{SHOPIFY_CONFORMANCE_STORE_DOMAIN}/api/{SHOPIFY_CONFORMANCE_API_VERSION}/graphql.json

