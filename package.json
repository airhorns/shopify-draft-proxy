    "conformance:capture-inventory-adjustments": "tsx ./scripts/capture-inventory-adjustment-conformance.mts",
    "conformance:capture-markets": "tsx ./scripts/capture-market-conformance.mts",
    "conformance:capture-marketing": "tsx ./scripts/capture-marketing-conformance.mts",
