    "conformance:capture-privacy": "tsx ./scripts/capture-privacy-conformance.ts",
    "conformance:capture-data-sale-opt-out": "tsx ./scripts/capture-data-sale-opt-out-conformance.ts",
    "conformance:capture-root-operations": "tsx ./scripts/capture-admin-graphql-root-operation-introspection.mts",
    "conformance:capture-orders": "tsx ./scripts/capture-order-conformance.mts",
    "conformance:capture-fulfillment-detail-events": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-fulfillment-detail-events-conformance.ts",
    "conformance:capture-draft-order-family": "tsx ./scripts/capture-draft-order-family-conformance.mts",
    "conformance:capture-draft-order-residual-helpers": "tsx ./scripts/capture-draft-order-residual-helper-conformance.mts",
    "conformance:capture-draft-order-invoice-send-safety": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-draft-order-invoice-send-safety-conformance.ts",
    "conformance:capture-discounts": "tsx ./scripts/capture-discount-conformance.ts",
    "conformance:capture-discount-lifecycle": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-discount-code-basic-lifecycle-conformance.ts",
    "conformance:capture-discount-bxgy-lifecycle": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-discount-bxgy-lifecycle-conformance.ts",
    "conformance:capture-discount-free-shipping-lifecycle": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-discount-free-shipping-lifecycle-conformance.ts",
    "conformance:capture-discount-validation": "tsx ./scripts/capture-discount-validation-conformance.ts",
    "conformance:capture-app-billing": "tsx ./scripts/capture-app-billing-conformance.ts",
    "conformance:capture-admin-platform": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-admin-platform-conformance.mts",
