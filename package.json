{
  "name": "shopify-draft-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "High-fidelity Shopify Admin GraphQL draft proxy for test environments",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --no-experimental-require-module src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --import-plugin -D no-console . && oxfmt --check .",
    "perf:smoke": "vitest run tests/integration/performance-smoke.test.ts",
    "conformance:check": "vitest run tests/unit/conformance-scenario-discovery.test.ts tests/unit/operation-registry.test.ts",
    "conformance:status": "tsx ./scripts/conformance-status-report.ts",
    "conformance:parity": "vitest run tests/unit/conformance-parity-scenarios.test.ts",
    "conformance:auth-link": "tsx ./scripts/generate-conformance-auth-link.mts",
    "conformance:exchange-auth": "tsx ./scripts/exchange-conformance-auth-callback.mts",
    "conformance:probe": "tsx ./scripts/conformance-probe.mts",
    "conformance:refresh-auth": "tsx ./scripts/refresh-conformance-auth.mts",
    "conformance:capture:index": "tsx ./scripts/conformance-capture-index.ts",
    "conformance:capture-products": "tsx ./scripts/capture-product-conformance.mts",
    "conformance:capture-customers": "tsx ./scripts/capture-customer-conformance.mts",
