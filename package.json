{
  "name": "shopify-draft-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "High-fidelity Shopify Admin GraphQL draft proxy for test environments",
  "type": "module",
  "main": "./js/dist/index.js",
  "types": "./js/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./js/dist/index.d.ts",
      "import": "./js/dist/index.js"
    }
  },
  "scripts": {
    "dev": "corepack pnpm --dir js dev",
    "start": "node js/dist/server.js",
    "build": "corepack pnpm --dir js build",
    "typecheck": "corepack pnpm --dir js build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/unit/conformance-scenario-discovery.test.ts tests/unit/operation-registry.test.ts tests/unit/conformance-capture-index.test.ts tests/unit/conformance-script-config.test.ts tests/unit/no-mjs-files.test.ts tests/integration/gleam-interop.test.ts tests/integration/gleam-js-http-adapter-parity.test.ts tests/integration/launch-scripts.test.ts",
    "test:watch": "vitest",
    "lint": "oxlint --import-plugin -D no-console . && oxfmt --check . && corepack pnpm gleam:format:check",
    "gleam:build": "gleam build --warnings-as-errors --target javascript && gleam build --warnings-as-errors --target erlang",
    "gleam:build:js": "gleam build --warnings-as-errors --target javascript",
    "gleam:build:erlang": "gleam build --warnings-as-errors --target erlang",
    "gleam:registry:check": "gleam format --check src/shopify_draft_proxy/proxy/operation_registry_data.gleam && vitest run tests/unit/operation-registry.test.ts",
    "gleam:port:coverage": "tsx ./scripts/gleam-port-coverage-gate.ts",
    "gleam:export:erlang": "gleam export erlang-shipment",
    "gleam:test": "corepack pnpm gleam:test:js && corepack pnpm gleam:test:erlang",
    "gleam:test:js": "corepack pnpm gleam:build:js && gleam test --target javascript",
    "gleam:test:erlang": "corepack pnpm gleam:build:erlang && gleam test --target erlang",
    "gleam:graphql-parity": "corepack pnpm gleam:build:js && tsx ./scripts/check-gleam-graphql-parser-parity.ts",
    "gleam:format": "gleam format src test",
    "gleam:format:check": "gleam format --check src test",
    "gleam:smoke:js": "vitest run tests/integration/gleam-interop.test.ts",
    "elixir:smoke": "tsx scripts/elixir-smoke.ts",
    "conformance:check": "tsx ./scripts/conformance-check.ts",
    "conformance:run": "tsx ./scripts/conformance-run.ts",
    "conformance:capture:check": "vitest run tests/unit/conformance-capture-index.test.ts tests/unit/conformance-script-config.test.ts tests/unit/no-mjs-files.test.ts",
    "conformance:status": "tsx ./scripts/conformance-status-report.ts",
    "linear:cache": "tsx ./scripts/build-linear-issue-cache.ts",
    "parity:record": "tsx ./scripts/parity-record.mts",
    "parity:run": "corepack pnpm gleam:test:js && corepack pnpm gleam:test:erlang",
    "conformance:auth-link": "tsx ./scripts/generate-conformance-auth-link.mts",
    "conformance:exchange-auth": "tsx ./scripts/exchange-conformance-auth-callback.mts",
    "conformance:probe": "tsx ./scripts/conformance-probe.mts",
    "conformance:refresh-auth": "tsx ./scripts/refresh-conformance-auth.mts",
    "conformance:capture": "tsx ./scripts/conformance-capture-index.ts",
    "conformance:capture:index": "tsx ./scripts/conformance-capture-index.ts",
    "conformance:capture-custom-data-field-types": "tsx ./scripts/capture-custom-data-field-type-conformance.ts",
    "conformance:probe-product-variant-compatibility-roots": "tsx ./scripts/probe-product-variant-compatibility-roots.mts",
    "e2e:product-create-commit-smoke": "tsx --no-experimental-require-module ./scripts/e2e-product-create-commit-smoke.mts",
    "e2e:elixir-product-create-commit-smoke": "tsx ./scripts/elixir-e2e-product-create-commit-smoke.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "graphql": "^16.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
