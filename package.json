  "dependencies": {
    "@koa/router": "^15.4.0",
    "dotenv": "^16.6.1",
    "graphql": "^16.11.0",
    "koa": "^2.16.3",
    "koa-bodyparser": "^4.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^24.6.1",
    "@types/supertest": "^6.0.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
