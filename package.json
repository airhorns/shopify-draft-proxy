    "conformance:capture-webhook-subscriptions": "SHOPIFY_CONFORMANCE_API_VERSION=2026-04 tsx ./scripts/capture-webhook-subscription-conformance.ts",
    "conformance:capture-gift-cards": "tsx ./scripts/capture-gift-card-conformance.ts"
