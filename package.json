{
  "name": "shopify-draft-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "High-fidelity Shopify Admin GraphQL draft proxy for test environments",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --no-experimental-require-module src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --import-plugin -D no-console . && oxfmt --check . && corepack pnpm gleam:format:check",
    "gleam:build": "cd gleam && gleam build --target javascript && gleam build --target erlang",
    "gleam:build:js": "cd gleam && gleam build --target javascript",
    "gleam:build:erlang": "cd gleam && gleam build --target erlang",
    "gleam:export:erlang": "cd gleam && gleam export erlang-shipment",
    "gleam:test": "cd gleam && gleam test --target javascript && gleam test --target erlang",
    "gleam:test:js": "cd gleam && gleam test --target javascript",
    "gleam:test:erlang": "cd gleam && gleam test --target erlang",
    "gleam:graphql-parity": "corepack pnpm gleam:build:js && tsx ./scripts/check-gleam-graphql-parser-parity.ts",
    "gleam:format": "cd gleam && gleam format",
    "gleam:format:check": "cd gleam && gleam format --check",
    "gleam:smoke:js": "vitest run tests/integration/gleam-interop.test.ts",
    "elixir:smoke": "tsx scripts/elixir-smoke.ts",
    "perf:smoke": "vitest run tests/integration/performance-smoke.test.ts",
    "conformance:check": "vitest run tests/unit/conformance-scenario-discovery.test.ts tests/unit/operation-registry.test.ts",
    "conformance:status": "tsx ./scripts/conformance-status-report.ts",
    "conformance:parity": "vitest run tests/unit/conformance-parity-scenarios.test.ts",
    "conformance:auth-link": "tsx ./scripts/generate-conformance-auth-link.mts",
    "conformance:exchange-auth": "tsx ./scripts/exchange-conformance-auth-callback.mts",
    "conformance:probe": "tsx ./scripts/conformance-probe.mts",
    "conformance:refresh-auth": "tsx ./scripts/refresh-conformance-auth.mts",
    "conformance:capture": "tsx ./scripts/conformance-capture-index.ts",
    "conformance:capture:index": "tsx ./scripts/conformance-capture-index.ts",
    "conformance:capture-custom-data-field-types": "tsx ./scripts/capture-custom-data-field-type-conformance.ts",
    "conformance:probe-product-variant-compatibility-roots": "tsx ./scripts/probe-product-variant-compatibility-roots.mts"
  },
  "dependencies": {
    "@koa/router": "^15.4.0",
    "dotenv": "^16.6.1",
    "graphql": "^16.11.0",
    "koa": "^2.16.3",
    "koa-bodyparser": "^4.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^24.6.1",
    "@types/supertest": "^6.0.3",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.18.3"
}
