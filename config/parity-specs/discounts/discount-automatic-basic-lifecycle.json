        "capturePath": "$.update.response.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/discounts/discount-automatic-basic-lifecycle-update.graphql",
          "variables": {
