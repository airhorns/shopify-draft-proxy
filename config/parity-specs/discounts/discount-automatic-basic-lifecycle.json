{
  "scenarioId": "discount-automatic-basic-lifecycle",
  "operationNames": [
    "discountAutomaticBasicCreate",
    "discountAutomaticBasicUpdate",
    "discountAutomaticDeactivate",
    "discountAutomaticActivate",
    "discountAutomaticDelete"
  ],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "selected-fields", "mutation-lifecycle", "read-after-write"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/discounts/discount-automatic-basic-lifecycle.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/discounts/discount-automatic-basic-lifecycle-create.graphql",
    "variablesCapturePath": "$.create.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Executable parity coverage for locally staged DiscountAutomaticBasic create/update/deactivate/activate/delete. Follow-up proxy requests use the primary local create response ID so the parity run validates local lifecycle continuity while accepting expected live-vs-synthetic IDs and deactivation timestamp differences.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.discountAutomaticBasicCreate.automaticDiscountNode.automaticDiscount.status",
        "matcher": "SCHEDULED",
        "reason": "This older lifecycle fixture used a startsAt value active at live capture time but scheduled against the proxy's deterministic synthetic clock; HAR-593 adds dedicated stable-date status parity."
      },
      {
        "path": "$.discountAutomaticBasicUpdate.automaticDiscountNode.automaticDiscount.status",
        "matcher": "SCHEDULED",
        "reason": "This older lifecycle fixture used a startsAt value active at live capture time but scheduled against the proxy's deterministic synthetic clock; HAR-593 adds dedicated stable-date status parity."
      },
      {
        "path": "$.discountAutomaticBasicCreate.automaticDiscountNode.id",
        "matcher": "shopify-gid:DiscountAutomaticNode",
        "reason": "The proxy creates a stable synthetic automatic discount ID instead of using Shopify's live ID."
      },
      {
        "path": "$.discountAutomaticBasicUpdate.automaticDiscountNode.id",
        "matcher": "shopify-gid:DiscountAutomaticNode",
        "reason": "The update runs against the proxy-created synthetic automatic discount ID."
      },
      {
        "path": "$.discountAutomaticDeactivate.automaticDiscountNode.id",
        "matcher": "shopify-gid:DiscountAutomaticNode",
        "reason": "The deactivate mutation runs against the proxy-created synthetic automatic discount ID."
      },
      {
        "path": "$.discountAutomaticDeactivate.automaticDiscountNode.automaticDiscount.endsAt",
        "matcher": "iso-timestamp",
        "reason": "Both Shopify and the proxy stamp deactivation with execution time; exact wall-clock value is intentionally not contractual."
      },
      {
        "path": "$.discountAutomaticDeactivate.automaticDiscountNode.automaticDiscount.startsAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy rewrites future local startsAt values to its deterministic synthetic-now timestamp during deactivation."
      },
      {
        "path": "$.discountAutomaticActivate.automaticDiscountNode.id",
        "matcher": "shopify-gid:DiscountAutomaticNode",
        "reason": "The activate mutation runs against the proxy-created synthetic automatic discount ID."
      },
      {
        "path": "$.discountAutomaticActivate.automaticDiscountNode.automaticDiscount.startsAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy rewrites stale local startsAt values to its deterministic synthetic-now timestamp during activation."
      },
      {
        "path": "$.discountAutomaticDelete.deletedAutomaticDiscountId",
        "matcher": "shopify-gid:DiscountAutomaticNode",
        "reason": "The delete mutation returns the proxy-created synthetic automatic discount ID."
      }
    ],
    "targets": [
      {
        "name": "automatic-basic-create-data",
        "capturePath": "$.create.response.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null
      },
      {
