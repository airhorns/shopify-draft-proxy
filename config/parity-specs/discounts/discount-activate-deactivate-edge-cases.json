  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "code-basic-edge-create",
        "capturePath": "$.create.response.payload.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.discountCodeBasicCreate.codeDiscountNode.id",
            "matcher": "shopify-gid:DiscountCodeNode",
            "reason": "The proxy stages a synthetic discount node ID instead of Shopify's live setup ID."
          },
          {
            "path": "$.discountCodeBasicCreate.codeDiscountNode.codeDiscount.startsAt",
            "matcher": "iso-timestamp",
            "reason": "Shopify normalizes the fixed input timestamp to whole-second form while the proxy preserves the submitted millisecond precision."
          }
        ]
      },
      {
        "name": "code-basic-deactivate-rewrites-dates",
        "capturePath": "$.deactivate.response.payload.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.discountCodeDeactivate.codeDiscountNode.codeDiscount.startsAt",
            "matcher": "iso-timestamp",
            "reason": "Synthetic timestamps are sourced from the proxy clock and move independently from the recorded Shopify capture."
          },
          {
            "path": "$.discountCodeDeactivate.codeDiscountNode.codeDiscount.endsAt",
            "matcher": "iso-timestamp",
            "reason": "Synthetic timestamps are sourced from the proxy clock and move independently from the recorded Shopify capture."
          },
          {
            "path": "$.discountCodeDeactivate.codeDiscountNode.id",
            "matcher": "shopify-gid:DiscountCodeNode",
            "reason": "The proxy returns the locally staged synthetic discount node ID instead of Shopify's live setup ID."
          }
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/discounts/discount-activate-deactivate-edge-deactivate.graphql",
          "apiVersion": "2026-04",
          "variables": {
