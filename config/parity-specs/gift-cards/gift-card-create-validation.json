{
  "scenarioId": "gift-card-create-validation",
  "operationNames": ["giftCardCreate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "validation-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/gift-cards/gift-card-create-validation.json"
  ],
  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/gift_cards_mutation_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/gift-cards/gift-card-create-validation.graphql",
    "variablesCapturePath": "$.proxyVariables.createValidation"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "HAR-692 captures and replays giftCardCreate validation behavior for initial value, code length, code format, duplicate code, missing customer, explicit success, and generated-code success. The live fixture uses a run-unique valid code because Shopify keeps gift-card code uniqueness scoped to the shop even after cleanup deactivation.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "zero initial value returns GREATER_THAN",
        "capturePath": "$.operations.createValidation.response.payload.data.zeroInitialValue",
        "proxyPath": "$.data.zeroInitialValue",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "short code returns TOO_SHORT",
        "capturePath": "$.operations.createValidation.response.payload.data.shortCode",
        "proxyPath": "$.data.shortCode",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "long code returns TOO_LONG",
        "capturePath": "$.operations.createValidation.response.payload.data.longCode",
        "proxyPath": "$.data.longCode",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "invalid code format returns INVALID",
        "capturePath": "$.operations.createValidation.response.payload.data.invalidCode",
        "proxyPath": "$.data.invalidCode",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "missing customer returns CUSTOMER_NOT_FOUND",
        "capturePath": "$.operations.createValidation.response.payload.data.missingCustomer",
        "proxyPath": "$.data.missingCustomer",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "explicit valid code success preserves stable money and errors",
        "capturePath": "$.operations.createValidation.response.payload.data.success",
        "proxyPath": "$.data.success",
        "expectedDifferences": [
          {
            "path": "$.giftCard.id",
            "matcher": "shopify-gid:GiftCard",
            "reason": "The proxy stages giftCardCreate locally and returns a synthetic GiftCard GID."
          },
          {
            "path": "$.giftCard.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses deterministic synthetic timestamps instead of Shopify's live clock."
          },
          {
            "path": "$.giftCard.updatedAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses deterministic synthetic timestamps instead of Shopify's live clock."
          }
        ]
      },
      {
        "name": "duplicate code returns captured already-taken error after local success",
        "capturePath": "$.operations.createValidation.response.payload.data.duplicate",
        "proxyPath": "$.data.duplicate",
        "selectedPaths": ["$.giftCard", "$.giftCardCode", "$.userErrors"]
      },
      {
        "name": "auto generated code success preserves stable money and errors",
        "capturePath": "$.operations.createValidation.response.payload.data.autoGenerated",
        "proxyPath": "$.data.autoGenerated",
        "expectedDifferences": [
          {
            "path": "$.giftCard.id",
            "matcher": "shopify-gid:GiftCard",
            "reason": "The proxy stages giftCardCreate locally and returns a synthetic GiftCard GID."
          },
          {
            "path": "$.giftCard.lastCharacters",
            "matcher": "non-empty-string",
            "reason": "The proxy generates a deterministic local gift-card code, so its last characters differ from Shopify's random code."
          },
          {
            "path": "$.giftCard.maskedCode",
            "matcher": "non-empty-string",
            "reason": "The proxy masks the deterministic local code, so maskedCode differs from Shopify's random code."
          },
          {
            "path": "$.giftCard.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses deterministic synthetic timestamps instead of Shopify's live clock."
          },
          {
            "path": "$.giftCard.updatedAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses deterministic synthetic timestamps instead of Shopify's live clock."
          },
          {
            "path": "$.giftCardCode",
            "matcher": "non-empty-string",
            "reason": "The proxy returns a deterministic 16-character Shopify-like generated code instead of Shopify's random generated code."
          }
        ]
      }
    ]
  }
}
