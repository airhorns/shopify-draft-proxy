    ],
    "targets": [
      {
        "name": "create-payload",
        "capturePath": "$.operations.paymentCustomizationCreate.response.data.paymentCustomizationCreate",
        "proxyPath": "$.data.paymentCustomizationCreate"
      },
      {
        "name": "immutable-update-payload",
        "capturePath": "$.operations.paymentCustomizationUpdateImmutable.response.data.paymentCustomizationUpdate",
        "proxyPath": "$.data.paymentCustomizationUpdate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/payments/payment-customization-immutable-update.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.paymentCustomizationCreate.paymentCustomization.id"
            },
            "input": {
              "fromCapturePath": "$.operations.paymentCustomizationUpdateImmutable.variables.input"
            }
          }
        }
      },
      {
        "name": "read-after-immutable-update",
        "capturePath": "$.reads.afterImmutableUpdate.response.data.paymentCustomization",
        "proxyPath": "$.data.paymentCustomization",
        "proxyRequest": {
          "documentPath": "config/parity-requests/payments/payment-customization-immutable-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.paymentCustomizationCreate.paymentCustomization.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:PaymentCustomization",
            "reason": "Shopify and the local proxy read independently generated payment customization IDs."
          }
        ]
      }
    ]
