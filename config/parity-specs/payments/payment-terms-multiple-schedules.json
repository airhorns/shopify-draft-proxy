  },
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-valid-payment-terms",
        "capturePath": "$.expectedSetupPayload.data.paymentTermsCreate",
        "proxyPath": "$.data.paymentTermsCreate",
        "expectedDifferences": [
          {
            "path": "$.paymentTerms.id",
            "matcher": "shopify-gid:PaymentTerms",
            "reason": "Shopify and the local proxy generate independent payment terms IDs for the setup request."
