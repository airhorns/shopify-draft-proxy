          "documentPath": "config/parity-requests/media/fileDelete-parity.graphql",
          "variables": {
            "fileIds": [
              {
                "fromPrimaryProxyPath": "$.data.fileCreate.files[0].id"
              }
            ]
          }
        }
      },
      {
        "name": "delete-wrong-typed-video-gid",
        "capturePath": "$.deleteWrongType.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/media/fileDelete-parity.graphql",
