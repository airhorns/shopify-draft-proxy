{
  "scenarioId": "draft-order-duplicate-live-parity",
  "operationNames": ["draftOrderDuplicate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/very-big-test-store.myshopify.com/2025-01/draft-order-duplicate-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/draftOrderDuplicate-parity-plan.graphql",
    "variablesPath": "config/parity-requests/draftOrderDuplicate-parity-plan.variables.json",
    "variablesCapturePath": "$.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Live capture duplicates a dedicated draft order and records the new draft plus immediate downstream `draftOrder(id:)` visibility. Shopify-generated duplicate IDs, names, invoice URLs, and line-item IDs are expected differences.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.id",
        "matcher": "shopify-gid:DraftOrder",
        "reason": "The live duplicate and local duplicate allocate independent draft order IDs."
      },
      {
        "path": "$.name",
        "matcher": "non-empty-string",
        "reason": "Shopify allocates draft order names from store state; local staging uses a deterministic synthetic sequence."
      },
      {
        "path": "$.invoiceUrl",
        "matcher": "non-empty-string",
        "reason": "Invoice URLs are generated independently by Shopify and the local proxy."
      },
      {
        "path": "$.lineItems.nodes[*].id",
        "matcher": "shopify-gid:DraftOrderLineItem",
        "reason": "The live duplicate and local duplicate allocate independent draft order line-item IDs."
      }
    ],
    "targets": [
      {
        "name": "mutation-user-errors",
        "capturePath": "$.mutation.response.data.draftOrderDuplicate.userErrors",
        "proxyPath": "$.data.draftOrderDuplicate.userErrors"
      },
      {
        "name": "mutation-draft-order",
        "capturePath": "$.mutation.response.data.draftOrderDuplicate.draftOrder",
        "proxyPath": "$.data.draftOrderDuplicate.draftOrder"
      },
      {
        "name": "downstream-draft-order",
        "capturePath": "$.downstreamRead.response.data.draftOrder",
        "proxyRequest": {
          "documentPath": "config/parity-requests/draftOrderCreate-downstream-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.draftOrderDuplicate.draftOrder.id"
            }
          }
        },
        "proxyPath": "$.data.draftOrder"
      }
    ]
  }
}
