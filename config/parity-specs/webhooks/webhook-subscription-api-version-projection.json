{
  "scenarioId": "webhook-subscription-api-version-projection",
  "operationNames": [
    "webhookSubscriptionCreate",
    "webhookSubscription",
    "webhookSubscriptions",
    "webhookSubscriptionDelete"
  ],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/webhooks/webhook-subscription-api-version-projection.json"
  ],
  "runtimeTestFiles": ["test/parity_test.gleam", "test/shopify_draft_proxy/proxy/webhooks_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/webhooks/webhook-subscription-api-version-create.graphql",
    "variablesCapturePath": "$.lifecycle.create.variables",
    "apiVersion": "2026-04",
    "headers": {
      "x-shopify-draft-proxy-api-version": "2026-07"
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Strict parity for WebhookSubscription.apiVersion projection. The scenario captures real Shopify create, detail, filtered connection, and cleanup delete around one disposable API-created HTTP webhook subscription, then replays the same request flow through local staging.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "create-payload-api-version",
        "capturePath": "$.lifecycle.create.response.payload.data.webhookSubscriptionCreate",
        "proxyPath": "$.data.webhookSubscriptionCreate",
        "expectedDifferences": [
          {
            "path": "$.webhookSubscription.id",
            "matcher": "shopify-gid:WebhookSubscription",
            "reason": "The proxy creates a stable synthetic webhook subscription ID instead of Shopify's live ID."
          },
          {
            "path": "$.webhookSubscription.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses its deterministic synthetic clock for locally staged webhook subscriptions."
          },
          {
            "path": "$.webhookSubscription.updatedAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy uses its deterministic synthetic clock for locally staged webhook subscriptions."
          }
        ]
      },
      {
        "name": "detail-api-version",
        "capturePath": "$.lifecycle.detail.response.payload.data.webhookSubscription",
        "proxyPath": "$.data.webhookSubscription",
        "proxyRequest": {
          "documentPath": "config/parity-requests/webhooks/webhook-subscription-api-version-detail.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.webhookSubscriptionCreate.webhookSubscription.id"
            }
          },
          "apiVersion": "2026-04",
          "headers": {
            "x-shopify-draft-proxy-api-version": "2026-07"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:WebhookSubscription",
            "reason": "The downstream read sees the proxy-created synthetic webhook subscription ID."
          },
          {
            "path": "$.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The downstream read sees the proxy synthetic create timestamp."
          },
          {
            "path": "$.updatedAt",
            "matcher": "iso-timestamp",
            "reason": "The downstream read sees the proxy synthetic update timestamp."
          }
        ]
      },
      {
        "name": "connection-node-api-version",
        "capturePath": "$.lifecycle.connection.response.payload.data.webhookSubscriptions",
        "proxyPath": "$.data.webhookSubscriptions",
        "proxyRequest": {
          "documentPath": "config/parity-requests/webhooks/webhook-subscription-api-version-list.graphql",
          "variablesCapturePath": "$.lifecycle.connection.variables",
          "apiVersion": "2026-04",
          "headers": {
            "x-shopify-draft-proxy-api-version": "2026-07"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.nodes[0].id",
            "matcher": "shopify-gid:WebhookSubscription",
            "reason": "The connection node sees the proxy-created synthetic webhook subscription ID."
          }
        ]
      },
      {
        "name": "delete-cleanup",
        "capturePath": "$.lifecycle.delete.response.payload.data.webhookSubscriptionDelete",
        "proxyPath": "$.data.webhookSubscriptionDelete",
        "proxyRequest": {
          "documentPath": "config/parity-requests/webhooks/webhookSubscriptionDelete-parity.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.webhookSubscriptionCreate.webhookSubscription.id"
            }
          },
          "apiVersion": "2026-04",
          "headers": {
            "x-shopify-draft-proxy-api-version": "2026-07"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.deletedWebhookSubscriptionId",
            "matcher": "shopify-gid:WebhookSubscription",
            "reason": "The delete returns the proxy-created synthetic webhook subscription ID."
          }
        ]
      }
    ]
  }
}
