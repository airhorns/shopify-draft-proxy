{
  "scenarioId": "collection-identifier-read",
  "operationNames": ["collectionByIdentifier", "collectionByHandle"],
  "scenarioStatus": "captured",
  "assertionKinds": [
    "payload-shape",
    "selected-fields",
    "nested-products-connection",
    "null-empty-behavior",
    "deprecated-root"
  ],
  "liveCaptureFiles": ["fixtures/conformance/very-big-test-store.myshopify.com/2025-01/collection-detail.json"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/collection-detail-read.graphql",
    "variablesPath": "config/parity-requests/collection-detail-read.variables.json"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Uses the captured collection detail fixture to seed the local collection graph, then replays equivalent selected-field reads through collectionByIdentifier id/handle branches and the deprecated collectionByHandle root. collectionByIdentifier customId remains intentionally null in local behavior until a collection unique-metafield fixture exists. The root-specific local replay targets use the custom collection slice because the smart collection fixture captures only the first product page, not enough local membership state to prove productsCount or hasProduct.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.products.edges[*].cursor",
        "matcher": "non-empty-string",
        "reason": "Shopify collection product cursors are opaque; local snapshot replay uses deterministic synthetic cursors."
      },
      {
        "path": "$.products.pageInfo.startCursor",
        "matcher": "non-empty-string",
        "reason": "Shopify collection product cursors are opaque; local snapshot replay uses deterministic synthetic cursors."
      },
      {
        "path": "$.products.pageInfo.endCursor",
        "matcher": "non-empty-string",
        "reason": "Shopify collection product cursors are opaque; local snapshot replay uses deterministic synthetic cursors."
      }
    ],
    "targets": [
      {
        "name": "captured collection detail seed",
        "capturePath": "$.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": "$"
      },
      {
        "name": "collectionByIdentifier id branch custom collection",
        "capturePath": "$.data.customCollection",
        "proxyPath": "$.data.customCollection",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/collection-identifier-read.graphql",
          "variablesPath": "config/parity-requests/collection-identifier-read.variables.json"
        }
      },
      {
        "name": "collectionByIdentifier handle branch custom collection",
        "capturePath": "$.data.customCollection",
        "proxyPath": "$.data.customCollectionByHandle",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/collection-identifier-read.graphql",
          "variablesPath": "config/parity-requests/collection-identifier-read.variables.json"
        }
      },
      {
        "name": "collectionByHandle deprecated root custom collection",
        "capturePath": "$.data.customCollection",
        "proxyPath": "$.data.customCollection",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/collection-handle-read.graphql",
          "variablesPath": "config/parity-requests/collection-identifier-read.variables.json"
        }
      }
    ]
  }
}
