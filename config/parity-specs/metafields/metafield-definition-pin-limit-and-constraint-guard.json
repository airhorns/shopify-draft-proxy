  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "pin-first-success",
        "capturePath": "$.primary.response.data.pin01",
        "proxyPath": "$.data.pin01",
        "expectedDifferences": [
          {
            "path": "$.pinnedDefinition.id",
            "matcher": "shopify-gid:MetafieldDefinition",
            "reason": "The proxy stages a deterministic synthetic definition ID while Shopify returned the live-store definition ID."
          }
        ]
      },
      {
        "name": "pin-fiftieth-success",
        "capturePath": "$.primary.response.data.pin50",
        "proxyPath": "$.data.pin50",
        "expectedDifferences": [
          {
            "path": "$.pinnedDefinition.id",
            "matcher": "shopify-gid:MetafieldDefinition",
            "reason": "The proxy stages a deterministic synthetic definition ID while Shopify returned the live-store definition ID."
          }
        ]
      },
      {
        "name": "pin-limit-reached-userErrors",
        "capturePath": "$.primary.response.data.pin51",
        "proxyPath": "$.data.pin51"
      },
      {
        "name": "pin-constrained-definition-userErrors",
        "capturePath": "$.primary.response.data.constrainedPin",
