      },
      {
        "name": "unpin-still-compacts-after-limit-guard",
        "capturePath": "$.unpinFirst.response.data.metafieldDefinitionUnpin",
        "proxyPath": "$.data.metafieldDefinitionUnpin",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-pin-limit-unpin.graphql",
