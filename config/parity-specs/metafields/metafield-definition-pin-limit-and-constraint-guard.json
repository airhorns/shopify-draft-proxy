      },
      {
        "name": "pinned-definitions-listing",
        "capturePath": "$.pinnedDefinitionsListing.data.metafieldDefinitions",
        "proxyPath": "$.data.metafieldDefinitions",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-pin-limit-listing.graphql",
