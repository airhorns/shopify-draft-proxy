{
  "scenarioId": "metafield-definition-automated-collection-dependency",
  "operationNames": [
    "productCreate",
    "metafieldDefinitionCreate",
    "metafieldsSet",
    "collectionCreate",
    "metafieldDefinitionDelete",
    "metafieldDefinition",
    "product",
    "collection"
  ],
  "scenarioStatus": "captured",
  "assertionKinds": [
    "payload-shape",
    "user-errors-parity",
    "downstream-read-parity",
    "runtime-staging",
    "no-upstream-passthrough"
  ],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/metafields/metafield-definition-automated-collection-dependency.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/metafields/metafield-definition-automated-collection-dependency-product-create.graphql",
    "apiVersion": "2026-04",
    "variablesCapturePath": "$.productCreate.request.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "product-create-setup",
        "capturePath": "$.productCreate.response.data.productCreate",
        "proxyPath": "$.data.productCreate",
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy stages a deterministic synthetic product ID while Shopify returned the live-store product ID."
          }
        ]
      },
      {
        "name": "definition-create-setup",
        "capturePath": "$.definitionCreate.response.data.metafieldDefinitionCreate",
        "proxyPath": "$.data.metafieldDefinitionCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-automated-collection-dependency-definition-create.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.definitionCreate.request.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.createdDefinition.id",
            "matcher": "shopify-gid:MetafieldDefinition",
            "reason": "The proxy stages a deterministic synthetic definition ID while Shopify returned the live-store definition ID."
          }
        ]
      },
      {
        "name": "metafields-set-setup",
        "capturePath": "$.metafieldsSet.response.data.metafieldsSet",
        "proxyPath": "$.data.metafieldsSet",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-automated-collection-dependency-metafields-set.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "metafields": [
              {
                "ownerId": {
                  "fromPrimaryProxyPath": "$.data.productCreate.product.id"
                },
                "namespace": {
                  "fromCapturePath": "$.metafieldsSet.request.variables.metafields[0].namespace"
                },
                "key": {
                  "fromCapturePath": "$.metafieldsSet.request.variables.metafields[0].key"
                },
                "type": {
                  "fromCapturePath": "$.metafieldsSet.request.variables.metafields[0].type"
                },
                "value": {
                  "fromCapturePath": "$.metafieldsSet.request.variables.metafields[0].value"
                }
              }
            ]
          }
        },
        "expectedDifferences": [
          {
            "path": "$.metafields[0].id",
            "matcher": "shopify-gid:Metafield",
            "reason": "The proxy stages a deterministic synthetic metafield ID while Shopify returned the live-store metafield ID."
          }
        ]
      },
      {
        "name": "automated-collection-create-setup",
        "capturePath": "$.collectionCreate.response.data.collectionCreate",
        "proxyPath": "$.data.collectionCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-automated-collection-dependency-collection-create.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "input": {
              "title": {
                "fromCapturePath": "$.collectionCreate.request.variables.input.title"
              },
              "ruleSet": {
                "appliedDisjunctively": false,
                "rules": [
                  {
                    "column": "PRODUCT_METAFIELD_DEFINITION",
                    "relation": "EQUALS",
                    "condition": "blue",
                    "conditionObjectId": {
                      "fromProxyResponse": "definition-create-setup",
                      "path": "$.data.metafieldDefinitionCreate.createdDefinition.id"
                    }
                  }
                ]
              }
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.collection.id",
            "matcher": "shopify-gid:Collection",
            "reason": "The proxy stages a deterministic synthetic collection ID while Shopify returned the live-store collection ID."
          },
          {
            "path": "$.collection.ruleSet.rules[0].conditionObject.metafieldDefinition.id",
            "matcher": "shopify-gid:MetafieldDefinition",
            "reason": "The collection rule points at the definition allocated independently by Shopify and the proxy."
          }
        ]
      },
      {
        "name": "read-before-delete",
        "capturePath": "$.readBeforeDelete.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafields/metafield-definition-automated-collection-dependency-read.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "definitionId": {
              "fromProxyResponse": "definition-create-setup",
