            },
            "namespace": {
              "fromCapturePath": "$.readBeforeDelete.request.variables.namespace"
            },
            "key": {
              "fromCapturePath": "$.readBeforeDelete.request.variables.key"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.metafieldDefinition.id",
            "matcher": "shopify-gid:MetafieldDefinition",
            "reason": "The proxy and Shopify allocate definition IDs independently."
          },
          {
