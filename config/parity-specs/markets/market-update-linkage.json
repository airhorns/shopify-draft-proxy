            "matcher": "shopify-gid:Market",
            "reason": "The proxy reads the deterministic synthetic source Market id created earlier in the parity replay."
          },
          {
            "path": "$.markets.nodes[1].id",
            "matcher": "shopify-gid:Market",
            "reason": "The proxy reads the deterministic synthetic target Market id created earlier in the parity replay."
          }
        ]
      },
      {
