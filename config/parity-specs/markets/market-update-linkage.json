        "capturePath": "$.cases[5].response.payload.data.catalog",
        "proxyPath": "$.data.catalog",
        "proxyRequest": {
          "documentPath": "config/parity-requests/markets/market-update-linkage-catalog-read.graphql",
          "variables": {
