{
  "scenarioId": "market-update-scalars",
  "operationNames": ["marketCreate", "marketUpdate", "market"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity", "local-staging"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/markets/market-update-scalars.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/metafields_markets_products_tail.rs"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/markets/market-update-scalars-create.graphql",
    "apiVersion": "2026-04",
    "variablesCapturePath": "$.cases[0].variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Live Admin GraphQL 2026-04 capture creates a disposable active market, updates name plus status to DRAFT, and verifies Shopify returns the updated name/status/enabled payload and downstream market(id:) read.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "market-create-scalar-update-setup",
        "capturePath": "$.cases[0].response.payload.data.marketCreate",
        "proxyPath": "$.data.marketCreate",
        "expectedDifferences": [
          {
            "path": "$.market.id",
            "matcher": "shopify-gid:Market",
            "reason": "The local proxy generates deterministic Market ids while the capture stores disposable live Shopify Market ids."
          }
        ]
      },
      {
        "name": "market-update-name-status-payload",
        "capturePath": "$.cases[1].response.payload.data.marketUpdate",
        "proxyPath": "$.data.marketUpdate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/markets/market-update-scalars-update.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.marketCreate.market.id"
            },
            "input": {
              "name": {
                "fromCapturePath": "$.cases[1].variables.input.name"
              },
              "status": {
                "fromCapturePath": "$.cases[1].variables.input.status"
              }
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.market.id",
            "matcher": "shopify-gid:Market",
            "reason": "The proxy updates the deterministic synthetic Market id created during replay."
          }
        ]
      },
      {
        "name": "market-update-name-status-read-after-write",
        "capturePath": "$.cases[2].response.payload.data.market",
        "proxyPath": "$.data.market",
        "proxyRequest": {
          "documentPath": "config/parity-requests/markets/market-update-scalars-read.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.marketCreate.market.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:Market",
            "reason": "The proxy reads the deterministic synthetic Market id created during replay."
          }
        ]
      }
    ]
  }
}
