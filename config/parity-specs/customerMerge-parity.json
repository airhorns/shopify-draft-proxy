{
  "scenarioId": "customer-merge-live-parity",
  "operationNames": [
    "customerMerge",
    "customerMergePreview",
    "customerMergeJobStatus",
    "customer",
    "customerByIdentifier",
    "customersCount",
    "customerAddressCreate",
    "orderCreate",
    "draftOrderCreate"
  ],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity", "runtime-staging"],
  "liveCaptureFiles": ["fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/customer-merge-parity.json"],
  "runtimeTestFiles": ["tests/integration/customer-draft-flow.test.ts"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/customerMerge-parity.graphql",
    "variablesCapturePath": "$.mutation.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Strict comparison covers the staged customerMerge payload, resulting customer downstream visibility, source customer deletion, customerByIdentifier email lookup behavior, merge job status shape, captured attached-resource transfer for normalized customer addresses, customer metafields, and orders, and captured missing/self/unknown validation branches. The live fixture also records an IN_PROGRESS poll followed by COMPLETED. Draft order setup is captured, but customer-merge draft-order transfer remains deferred until a downstream draft-order read is captured.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.customerMerge.job.id",
        "matcher": "shopify-gid:Job",
        "reason": "Customer merge jobs are allocated independently by Shopify and the local staging identity registry."
      },
      {
        "path": "$.result.updatedAt",
        "matcher": "iso-timestamp",
        "reason": "The downstream proxy read observes the deterministic local merge timestamp instead of Shopify's live write timestamp."
      },
      {
        "path": "$.result.addressesV2.pageInfo.startCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors."
      },
      {
        "path": "$.result.addressesV2.pageInfo.endCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors."
      },
      {
        "path": "$.result.metafields.nodes[2].id",
        "matcher": "shopify-gid:Metafield",
        "reason": "Shopify allocates a new metafield ID when copying a source-only customer metafield during merge; the local proxy allocates its own synthetic metafield ID."
      },
      {
        "path": "$.result.metafields.pageInfo.startCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors."
      },
      {
        "path": "$.result.metafields.pageInfo.endCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors and the copied source-only metafield receives a local ID."
      },
      {
        "path": "$.result.orders.pageInfo.startCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors."
      },
      {
        "path": "$.result.orders.pageInfo.endCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy uses deterministic synthetic cursors."
      },
      {
        "path": "$.mergeStatus.jobId",
        "matcher": "shopify-gid:Job",
        "reason": "The downstream proxy job-status read uses the locally generated merge job ID."
      }
    ],
    "targets": [
      {
        "name": "mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyPath": "$.data"
      },
      {
        "name": "downstream-read-data",
        "capturePath": "$.downstreamRead.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customer-merge-downstream-read.graphql",
          "variablesCapturePath": "$.downstreamRead.proxyVariables"
        }
      },
      {
        "name": "self-merge-validation-data",
        "capturePath": "$.validation.selfMerge.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customerMerge-parity.graphql",
          "variablesCapturePath": "$.validation.selfMerge.variables"
        }
      },
      {
        "name": "unknown-customer-validation-data",
        "capturePath": "$.validation.unknownCustomer.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customerMerge-parity.graphql",
          "variables": {
            "one": {
              "fromPrimaryProxyPath": "$.data.customerMerge.resultingCustomerId"
            },
            "two": "gid://shopify/Customer/999999999999999"
          }
        }
      },
      {
        "name": "missing-argument-validation-message",
        "capturePath": "$.validation.missingArgument.response.errors[0].message",
        "proxyPath": "$.errors[0].message",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customerMerge-missing-argument.graphql",
          "variablesCapturePath": "$.validation.missingArgument.variables"
        }
      },
      {
        "name": "missing-argument-validation-extensions",
        "capturePath": "$.validation.missingArgument.response.errors[0].extensions",
        "proxyPath": "$.errors[0].extensions",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customerMerge-missing-argument.graphql",
          "variablesCapturePath": "$.validation.missingArgument.variables"
        }
      }
    ]
  }
}
