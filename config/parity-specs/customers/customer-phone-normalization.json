  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Captured Admin GraphQL phone normalization behavior for CustomerInput and CustomerSetInput: formatted customerCreate/customerUpdate values normalize to E.164, duplicate checks compare normalized forms, invalid phones return INVALID, and >255-grapheme phone input returns Shopify's too-long validation shape. Follow-up requests reuse state staged by earlier runner requests rather than pre-seeding.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.customerCreate.customer.id",
        "matcher": "shopify-gid:Customer",
        "reason": "The proxy stages customerCreate locally and returns a stable synthetic Customer GID instead of Shopify's live Customer GID."
      },
      {
        "path": "$.customerCreate.customer.createdAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy stages customerCreate with a deterministic local timestamp while Shopify returns the live write timestamp."
      },
      {
        "path": "$.customerCreate.customer.updatedAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy stages customerCreate with a deterministic local timestamp while Shopify returns the live write timestamp."
      },
      {
        "path": "$.customerUpdate.customer.id",
        "matcher": "shopify-gid:Customer",
        "reason": "The proxy stages customerUpdate locally over a synthetic Customer GID while Shopify returns the live Customer GID."
      },
      {
        "path": "$.customerUpdate.customer.createdAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy preserves a deterministic local create timestamp while Shopify returns the live create timestamp."
      },
      {
        "path": "$.customerUpdate.customer.updatedAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy stages customerUpdate with a deterministic local update timestamp while Shopify returns the live write timestamp."
      }
    ],
    "targets": [
