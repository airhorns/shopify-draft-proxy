{
  "scenarioId": "customer_delete_no_orders_control",
  "operationNames": ["customerCreate", "customerDelete", "customer"],
  "scenarioStatus": "captured",
  "assertionKinds": ["runtime-staging", "downstream-read-parity", "no-upstream-passthrough"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/customers/customer-delete-no-orders-control.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/admin_app_shipping.rs"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/customers/customer-delete-order-precondition-customer-create.graphql",
    "variablesCapturePath": "$.setup.customerCreate.variables",
    "apiVersion": "2025-01"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-customer",
        "capturePath": "$.expected.customerCreate.data.customerCreate.userErrors",
        "proxyPath": "$.data.customerCreate.userErrors"
      },
      {
        "name": "delete-no-orders",
        "capturePath": "$.expected.customerDelete.data.customerDelete",
        "proxyPath": "$.data.customerDelete",
        "expectedDifferences": [
          {
            "path": "$.deletedCustomerId",
            "matcher": "shopify-gid:Customer",
            "reason": "The proxy deletes the customer staged by the primary proxy request and returns that synthetic Customer GID instead of Shopify's live Customer GID."
          }
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/customers/customer-delete-order-precondition-delete.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.customerCreate.customer.id"
              }
            }
          },
          "apiVersion": "2025-01"
        }
      },
      {
        "name": "read-after-delete",
        "capturePath": "$.expected.readAfterDelete.data.customer",
        "proxyPath": "$.data.customer",
        "proxyRequest": {
          "documentPath": "config/parity-requests/customers/customer-delete-order-precondition-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.customerCreate.customer.id"
            }
          },
          "apiVersion": "2025-01"
        }
      }
    ]
  },
  "notes": "Live Shopify Admin GraphQL 2025-01 control proving customerDelete succeeds when the customer has no associated orders, and downstream customer(id:) returns null afterward."
}
