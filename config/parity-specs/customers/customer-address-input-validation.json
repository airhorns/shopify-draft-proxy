{
  "scenarioId": "customer-address-input-validation",
  "operationNames": ["customerCreate", "customerSet", "customerAddressCreate", "customerAddressUpdate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/customers/customer-address-input-validation.json"
  ],
  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/customers_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/customers/customerInputValidation-create.graphql",
    "variablesCapturePath": "$.setupCustomer.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Captured Admin GraphQL 2025-01 evidence for customer address input length, HTML, URL, emoji, blank-address, and whitespace normalization behavior across CustomerInput, CustomerSetInput, and dedicated address mutations. Dedicated customerAddressCreate and customerSet accept all-blank address strings after normalizing them to null; nested CustomerInput.addresses rejects an all-blank address entry.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.address.id",
        "matcher": "any-string",
        "reason": "The proxy stages customer addresses locally and returns stable synthetic MailingAddress IDs instead of Shopify live IDs."
      },
      {
        "path": "$.customer.id",
        "matcher": "shopify-gid:Customer",
        "reason": "The proxy stages the setup customer locally and returns its stable synthetic Customer GID in the customerSet payload."
      },
      {
        "path": "$.customer.createdAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy stages the setup customer locally and returns a deterministic synthetic timestamp instead of Shopify's live timestamp."
      },
      {
        "path": "$.customer.updatedAt",
        "matcher": "iso-timestamp",
        "reason": "The proxy stages customerSet locally and returns a deterministic synthetic timestamp instead of Shopify's live timestamp."
      },
      {
        "path": "$.customer.addressesV2.nodes[*].id",
        "matcher": "any-string",
        "reason": "The proxy stages customerSet replacement addresses locally and returns stable synthetic MailingAddress IDs instead of Shopify live IDs."
      },
      {
        "path": "$.customer.addressesV2.pageInfo.startCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy emits deterministic synthetic cursors."
      },
      {
        "path": "$.customer.addressesV2.pageInfo.endCursor",
        "matcher": "any-string",
        "reason": "Shopify connection cursors are opaque and the local proxy emits deterministic synthetic cursors."
      }
    ],
