  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-enable-french-locale",
        "capturePath": "$.setup.localeSetup.response.data.shopLocaleEnable",
        "proxyPath": "$.data.shopLocaleEnable",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-shop-locale-enable.graphql",
          "apiVersion": "2026-04",
          "variables": { "locale": "fr" }
        },
        "expectedDifferences": [
          {
            "path": "$.shopLocale",
            "ignore": true,
            "regrettable": true,
            "reason": "The live shop may already have French enabled, while parity replay always enables it on a clean proxy to satisfy translationsRegister locale validation before the digest assertions."
          },
          {
            "path": "$.userErrors",
            "ignore": true,
            "regrettable": true,
            "reason": "The setup branch is environment-dependent and is not the behavior under test; digest validation targets below are strict."
          }
        ]
      },
      {
        "name": "setup-product-create",
        "capturePath": "$.setup.productCreate.response.data.productCreate",
        "proxyPath": "$.data.productCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translations-digest-product-create.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.setup.productCreate.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy allocates a synthetic product GID while Shopify returns a real disposable product GID."
