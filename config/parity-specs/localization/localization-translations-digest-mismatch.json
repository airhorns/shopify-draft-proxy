          "documentPath": "config/parity-requests/localization/localization-translations-register.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "translations": {
              "fromCapturePath": "$.wrongDigestRegister.variables.translations"
            }
          }
        }
      },
      {
