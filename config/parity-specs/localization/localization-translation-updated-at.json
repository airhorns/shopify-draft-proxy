{
  "scenarioId": "localization-translation-updated-at",
  "operationNames": ["productCreate", "shopLocaleEnable", "translationsRegister", "translatableResource"],
  "scenarioStatus": "captured",
  "assertionKinds": [
    "payload-shape",
    "downstream-read-parity",
    "translation-updated-at-ordering",
    "failed-mutation-timestamp-stability"
  ],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/localization/localization-translation-updated-at.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/discounts_gift_cards_functions_localization.rs"],
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-enable-french-locale",
        "capturePath": "$.setup.localeSetup.response.data.shopLocaleEnable",
        "proxyPath": "$.data.shopLocaleEnable",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-shop-locale-enable.graphql",
          "apiVersion": "2026-04",
          "variables": { "locale": "fr" }
        },
        "expectedDifferences": [
          {
            "path": "$.shopLocale",
            "ignore": true,
            "regrettable": true,
            "reason": "The live shop may already have French enabled, while parity replay enables it on a clean proxy before translationsRegister."
          },
          {
            "path": "$.userErrors",
            "ignore": true,
            "regrettable": true,
            "reason": "The setup locale branch is environment-dependent and is not the updatedAt behavior under test."
          }
        ]
      },
      {
        "name": "setup-product-create",
        "capturePath": "$.setup.productCreate.response.data.productCreate",
        "proxyPath": "$.data.productCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translations-digest-product-create.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.setup.productCreate.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy allocates a synthetic Product GID while Shopify returns the real disposable Product GID captured from the live shop."
          }
        ]
      },
      {
        "name": "translations-register-initial-updated-at",
        "capturePath": "$.initialRegister.response.data.translationsRegister",
        "proxyPath": "$.data.translationsRegister",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translation-updated-at-register.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "translations": {
              "fromCapturePath": "$.initialRegister.variables.translations"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.translations[0].updatedAt",
            "matcher": "iso-timestamp",
            "reason": "Shopify and the proxy stamp translations at different times; parity requires the field to be present with a DateTime-shaped value."
          }
        ]
      },
      {
        "name": "translations-register-update-advances-updated-at",
        "capturePath": "$.updateRegister.response.data.translationsRegister",
        "proxyPath": "$.data.translationsRegister",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translation-updated-at-register.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "translations": {
              "fromCapturePath": "$.updateRegister.variables.translations"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.translations[0].updatedAt",
            "matcher": "iso-timestamp",
            "reason": "Shopify and the proxy stamp translations at different times; parity requires the field to be present with a DateTime-shaped value. The capture script asserts this timestamp advanced from the initial successful register."
          }
        ]
      },
      {
        "name": "translatable-resource-updated-at-read-after-update",
        "capturePath": "$.downstreamRead.response.data.translatableResource",
        "proxyPath": "$.data.translatableResource",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translation-updated-at-read.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.resourceId",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy reads back the synthetic local Product GID while the live capture reads the disposable Shopify Product GID."
          },
          {
            "path": "$.translations[0].updatedAt",
            "matcher": "iso-timestamp",
            "reason": "Shopify and the proxy stamp translations at different times; parity requires the downstream row to retain a DateTime-shaped value."
          }
        ]
      },
      {
        "name": "translations-register-rejected-invalid-digest",
        "capturePath": "$.rejectedRegister.response.data.translationsRegister",
        "proxyPath": "$.data.translationsRegister",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translation-updated-at-register.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "translations": {
              "fromCapturePath": "$.rejectedRegister.variables.translations"
            }
          }
        }
      },
      {
        "name": "translatable-resource-updated-at-read-after-rejected-update",
        "capturePath": "$.downstreamReadAfterRejected.response.data.translatableResource",
        "proxyPath": "$.data.translatableResource",
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translation-updated-at-read.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "setup-product-create",
              "path": "$.data.productCreate.product.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.resourceId",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy reads back the synthetic local Product GID while the live capture reads the disposable Shopify Product GID."
          },
          {
            "path": "$.translations[0].updatedAt",
            "matcher": "iso-timestamp",
            "reason": "Shopify and the proxy stamp translations at different times; parity requires the downstream row to retain a DateTime-shaped value. The capture script asserts the rejected stale-digest update left this timestamp unchanged from the successful update."
          }
        ]
      }
    ]
  },
  "notes": "Live Admin GraphQL 2026-04 capture extends the localization digest/known-resource flow: it creates a disposable product, enables French, reads the product title digest, registers an initial valid title translation while selecting Translation.updatedAt, waits across Shopify's second-precision timestamp boundary, updates the same title translation, reads it back through translatableResource(...).translations, verifies a rejected stale-digest update leaves the readback timestamp stable, then deletes the product and restores the locale only when the script enabled it. Absolute timestamp values remain volatile in proxy parity; ordering and failed-update stability are enforced by the registered capture script plus runtime clock tests."
}
