{
  "scenarioId": "localization-translations-unknown-resource",
  "operationNames": ["productCreate", "translationsRegister", "translationsRemove"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "mutation-lifecycle"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2026-04/localization/localization-translations-unknown-resource.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/discounts_gift_cards_functions_localization.rs"],
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "translations-register-remove-unknown-product-resource",
        "capturePath": "$.unknownResource.response.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-unknown-resource-validation.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.unknownResource.variables"
        }
      },
      {
        "name": "translations-register-remove-missing-collection-resource",
        "capturePath": "$.unknownCollectionResource.response.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-unknown-resource-validation.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.unknownCollectionResource.variables"
        }
      },
      {
        "name": "translations-register-remove-absent-menu-resource",
        "capturePath": "$.unknownMenuResource.response.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-unknown-resource-validation.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.unknownMenuResource.variables"
        }
      },
      {
        "name": "french-locale-enable",
        "capturePath": "$.setup.localeSetup.data.shopLocaleEnable",
        "proxyPath": "$.data.shopLocaleEnable",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-shop-locale-enable.graphql",
          "apiVersion": "2026-04",
          "variables": { "locale": "fr" }
        }
      },
      {
        "name": "known-product-create",
        "capturePath": "$.setup.productCreate.response.data.productCreate",
        "proxyPath": "$.data.productCreate",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translations-known-resource-product-create.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.setup.productCreate.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy allocates a local synthetic Product GID while the live capture records the disposable Shopify Product GID."
          }
        ]
      },
      {
        "name": "translations-register-known-product-resource",
        "capturePath": "$.knownRegister.response.data.translationsRegister",
        "proxyPath": "$.data.translationsRegister",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translations-register.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "known-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "translations": {
              "fromCapturePath": "$.knownRegister.variables.translations"
            }
          }
        }
      },
      {
        "name": "translations-remove-known-product-resource",
        "capturePath": "$.knownRemove.response.data.translationsRemove",
        "proxyPath": "$.data.translationsRemove",
        "upstreamCapturePath": null,
        "selectedPaths": [
          "$.translations[0].key",
          "$.translations[0].value",
          "$.translations[0].locale",
          "$.userErrors"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/localization/localization-translations-remove.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "resourceId": {
              "fromProxyResponse": "known-product-create",
              "path": "$.data.productCreate.product.id"
            },
            "keys": {
              "fromCapturePath": "$.knownRemove.variables.keys"
            },
            "locales": {
              "fromCapturePath": "$.knownRemove.variables.locales"
            }
          }
        }
      }
    ]
  },
  "notes": "Live Admin GraphQL 2026-04 capture creates one disposable product and ensures French is enabled. The unknown-resource targets prove translationsRegister and translationsRemove both return RESOURCE_NOT_FOUND for a well-formed absent Product GID, a missing Collection GID, and an absent Menu GID. Ordered local parity targets then create a proxy-local product and prove the same translation register/remove lifecycle still succeeds for a known local Product resource without runtime Shopify writes."
}
