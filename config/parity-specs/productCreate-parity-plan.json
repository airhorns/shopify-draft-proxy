{
  "scenarioId": "product-create-live-parity",
  "operationNames": ["productCreate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity"],
  "liveCaptureFiles": ["fixtures/conformance/very-big-test-store.myshopify.com/2025-01/product-create-parity.json"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/productCreate-parity-plan.graphql",
    "variablesPath": "config/parity-requests/productCreate-parity-plan.variables.json"
  },
  "comparison": {
    "mode": "strict-json",
    "allowedDifferences": [
      {
        "path": "$.productCreate.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The proxy generates a stable local product GID for the staged session; Shopify returns the dev-store product GID."
      },
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The downstream proxy read uses the stable local product GID generated by the staged productCreate response."
      }
    ],
    "targets": [
      {
        "name": "mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyPath": "$.data"
      },
      {
        "name": "downstream-read-data",
        "capturePath": "$.downstreamRead.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/productCreate-downstream-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            }
          }
        },
        "proxyPath": "$.data"
      }
    ]
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Live capture recorded for safe productCreate plus downstream read parity. This scenario is promoted to executed proxy-vs-Shopify comparison for mutation data and immediate downstream product read data. Shopify cost extensions remain outside this first explicit contract until the proxy synthesizes cost metadata."
}
