{
  "scenarioId": "marketing-activity-per-app-scoping",
  "scenarioStatus": "draft",
  "assertionKinds": ["user-errors-parity", "payload-shape", "local-state"],
  "operationNames": [
    "marketingActivityCreateExternal",
    "marketingActivityUpdateExternal",
    "marketingActivityUpsertExternal",
    "marketingActivityDeleteExternal",
    "marketingActivitiesDeleteAllExternal",
    "marketingEngagementCreate"
  ],
  "liveCaptureFiles": [],
  "proxyRequest": {
    "documentPath": "config/parity-requests/marketing/marketing-activity-per-app-scoping.graphql",
    "variables": {
      "appAActivityInput": {
        "title": "App A Campaign",
        "remoteId": "app-a-campaign",
        "status": "ACTIVE",
        "remoteUrl": "https://example.com/app-a",
        "tactic": "AD",
        "marketingChannelType": "DISPLAY",
        "channelHandle": "app-a-channel",
        "utm": { "campaign": "app-a", "source": "app-a", "medium": "display" }
      },
      "appBSelector": {
        "remoteId": "app-a-campaign"
      },
      "appBUpdateInput": {
        "title": "Hijacked by App B"
      },
      "appBEngagement": {
        "occurredOn": "2026-04-01",
        "isCumulative": false,
        "utcOffset": "+00:00",
        "adSpend": { "amount": "5.00", "currencyCode": "USD" }
      }
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Real Shopify scopes every external marketing activity write/read by (shop_id, api_client_id). MarketingActivityExternalHelper.find_marketing_activity joins by api_client_id, so App B cannot see, update, upsert, delete, or attach engagements to App A's external activities; missing-from-its-perspective records return MARKETING_ACTIVITY_DOES_NOT_EXIST. marketingActivityUpdate gates pre_resolve_access on api_client.id == ::MarketingActivity.find_by(id:, shop_id:).api_client_id. The proxy keys all staged_state by shop only and therefore lets App B mutate App A activities, see them in reads, and have marketingActivitiesDeleteAllExternal wipe activities owned by other apps. This spec drives both apps in sequence and asserts cross-app isolation.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "appB-updateExternal-by-remoteId-userErrors",
        "capturePath": null,
        "proxyPath": "$.data.appBUpdate.userErrors",
        "expected": [{ "field": ["remoteId"], "code": "MARKETING_ACTIVITY_DOES_NOT_EXIST" }]
      },
      {
        "name": "appB-deleteExternal-by-remoteId-userErrors",
        "capturePath": null,
        "proxyPath": "$.data.appBDelete.userErrors",
        "expected": [{ "field": ["remoteId"], "code": "MARKETING_ACTIVITY_DOES_NOT_EXIST" }]
      },
      {
        "name": "appA-activity-survives-appB-deleteAllExternal",
        "capturePath": null,
        "proxyPath": "$.data.appAReadAfterAppBDeleteAll.marketingActivities.nodes[?(@.title=='App A Campaign')]",
        "expected": "non-empty"
      },
      {
        "name": "appB-engagement-on-foreign-activity",
        "capturePath": null,
        "proxyPath": "$.data.appBEngagement.userErrors",
        "expected": [{ "field": ["remoteId"], "code": "MARKETING_ACTIVITY_DOES_NOT_EXIST" }]
      }
    ]
  }
}
