        "proxyRequest": {
          "documentPath": "config/parity-requests/shipping-fulfillments/carrier-service-lifecycle-update.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.carrierServiceCreate.carrierService.id"
              },
              "name": "Hermes Carrier Updated",
              "callbackUrl": "https://mock.shop/carrier-service-rates-updated",
              "supportsServiceDiscovery": false,
              "active": true
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.carrierService.id",
            "matcher": "shopify-gid:DeliveryCarrierService",
            "reason": "The update runs against the proxy-created synthetic carrier-service ID."
