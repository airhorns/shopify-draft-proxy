  "notes": "Captured Admin GraphQL 2026-04 DeliveryCarrierService evidence covers empty catalog/detail reads, active/id query filters, current-schema delete root presence, create/update/delete lifecycle payloads, blank-name and unknown-id userErrors, and downstream carrierService/carrierServices visibility. This spec now replays the staged lifecycle through the local proxy parity harness with strict comparison targets for create, update, downstream active/detail reads, delete, after-delete absence, and validation branches. The downstream proxy request intentionally compares the captured active-filter/detail behavior and omits Shopify's opaque id-filter cursor branch because the proxy uses synthetic carrier-service IDs during isolated replay.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "carrier-create-payload",
        "capturePath": "$.interactions[2].response.body.data.carrierServiceCreate",
        "proxyPath": "$.data.carrierServiceCreate",
        "upstreamCapturePath": null,
        "expectedDifferences": [
          {
            "path": "$.carrierService.id",
            "matcher": "shopify-gid:DeliveryCarrierService",
            "reason": "The proxy creates a stable synthetic carrier-service ID instead of Shopify's live ID."
          }
        ]
      },
