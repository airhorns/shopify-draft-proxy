  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/shipping_fulfillments_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/shipping-fulfillments/fulfillment-event-create-validation.graphql",
    "apiVersion": "2026-04",
    "variablesCapturePath": "$.unknownFulfillmentEventCreate.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "HAR-582/HAR-744 captured Admin GraphQL 2026-04 fulfillmentEventCreate validation and success behavior against a disposable fulfilled order. Public Admin GraphQL does not expose a code field on this mutation's UserError; selecting userErrors.code returns top-level undefinedField, so executable parity compares public field/message shape while runtime tests assert the ticket's source-backed local code values. Invalid FulfillmentEventStatus variables fail top-level INVALID_VARIABLE coercion and the captured enum includes DELAYED and CARRIER_PICKED_UP; invalid-enum parity compares that GraphQL validation envelope. The fixture also records that public 2026-04 accepted an event after fulfillmentCancel on the sampled fulfillment; the proxy retains the HAR-582 internal-source cancellation guard as the documented public-vs-internal boundary.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.errors[0].locations",
        "ignore": true,
        "regrettable": true,
        "reason": "The local proxy reproduces Shopify's invalid enum variable error message/extensions but does not run full schema validation location tracking."
      }
    ],
    "targets": [
      {
        "name": "unknown-fulfillment-user-error",
        "capturePath": "$.unknownFulfillmentEventCreate.response.data.fulfillmentEventCreate",
        "proxyPath": "$.data.fulfillmentEventCreate",
        "selectedPaths": ["$.fulfillmentEvent", "$.userErrors[0].field", "$.userErrors[0].message"]
      },
      {
        "name": "valid-event-create",
        "capturePath": "$.fulfillmentEventCreate.response.data.fulfillmentEventCreate",
        "proxyPath": "$.data.fulfillmentEventCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/shipping-fulfillments/fulfillment-event-create-validation.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.fulfillmentEventCreate.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.fulfillmentEvent.id",
            "matcher": "shopify-gid:FulfillmentEvent",
            "reason": "The proxy creates a stable synthetic FulfillmentEvent ID instead of Shopify's live ID."
          },
          {
            "path": "$.fulfillmentEvent.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The proxy emits a deterministic local createdAt timestamp for staged fulfillment events."
          }
        ]
      },
      {
        "name": "invalid-enum-variable-errors",
        "capturePath": "$.invalidStatusVariable.response",
        "proxyPath": "$",
        "proxyRequest": {
          "documentPath": "config/parity-requests/shipping-fulfillments/fulfillment-event-create-validation.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.invalidStatusVariable.variables"
        }
      },
      {
        "name": "event-detail-read-after-create",
        "capturePath": "$.detailRead.response.data.fulfillment",
        "proxyPath": "$.data.fulfillment",
        "proxyRequest": {
          "documentPath": "config/parity-requests/shipping-fulfillments/fulfillment-event-create-detail-read.graphql",
          "apiVersion": "2026-04",
          "variablesCapturePath": "$.detailRead.variables"
        },
        "selectedPaths": [
          "$.status",
          "$.displayStatus",
          "$.estimatedDeliveryAt",
          "$.inTransitAt",
          "$.events.nodes[0].status",
          "$.events.nodes[0].message",
