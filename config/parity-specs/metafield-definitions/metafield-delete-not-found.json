          "documentPath": "config/parity-requests/metafield-definitions/metafield-delete-by-id.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.metafieldsSet.metafields[0].id"
              }
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.deletedId",
            "matcher": "shopify-gid:Metafield",
            "reason": "The delete returns the staged setup metafield ID generated by the proxy."
          }
        ]
      },
      {
        "name": "repeat-delete-by-just-deleted-id",
        "capturePath": "$.expected.repeatDelete.response.data.metafieldDelete",
        "proxyPath": "$.data.metafieldDelete",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafield-definitions/metafield-delete-by-id.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.metafieldsSet.metafields[0].id"
              }
            }
          }
        }
      },
      {
        "name": "delete-never-created-id",
        "capturePath": "$.expected.neverCreatedDelete.response.data.metafieldDelete",
        "proxyPath": "$.data.metafieldDelete",
        "proxyRequest": {
          "documentPath": "config/parity-requests/metafield-definitions/metafield-delete-by-id.graphql",
          "apiVersion": "2026-04",
          "variables": {
            "input": {
              "id": "gid://shopify/Metafield/never-created"
            }
          }
        }
      }
    ]
  },
  "notes": "Executable local-runtime coverage for the singular `metafieldDelete` compatibility root: happy-path delete of a staged metafield ID, repeat delete of that just-deleted ID, and delete of a never-created ID. Public Admin GraphQL schema probes through 2026-04 and unstable expose only `metafieldsDelete`, so real public-Shopify evidence for the singular root is not available; the current public-root live evidence remains in `config/parity-specs/products/metafieldsDelete-parity-plan.json`."
