    "variables": {
      "metafields": [
        {
          "ownerId": "gid://shopify/Product/1",
          "namespace": "custom",
          "key": "delete_me",
          "type": "single_line_text_field",
          "value": "staged"
        }
      ]
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-metafields-set",
        "capturePath": "$.expected.setup.response.data.metafieldsSet",
        "proxyPath": "$.data.metafieldsSet",
        "expectedDifferences": [
          {
            "path": "$.metafields[0].id",
            "matcher": "shopify-gid:Metafield",
            "reason": "The local proxy creates a deterministic synthetic metafield ID for the staged setup record."
          }
        ]
      },
      {
        "name": "happy-delete-by-staged-id",
        "capturePath": "$.expected.happyDelete.response.data.metafieldDelete",
        "proxyPath": "$.data.metafieldDelete",
