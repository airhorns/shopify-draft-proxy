{
  "scenarioId": "product-create-inventory-read-live-parity",
  "operationNames": ["productCreate", "productVariant", "inventoryItem"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/very-big-test-store.myshopify.com/2025-01/product-create-inventory-read-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/productCreate-inventory-read-parity.graphql",
    "variablesPath": "config/parity-requests/productCreate-inventory-read-parity.variables.json",
    "variablesCapturePath": "$.mutation.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Covers the synthetic inventory item created for Shopify's default variant during `productCreate`, plus immediate downstream `productVariant(id:)` and `inventoryItem(id:)` reads using the staged synthetic IDs.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.productCreate.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The proxy allocates a stable synthetic product GID for staged productCreate."
      },
      {
        "path": "$.productCreate.product.variants.nodes[0].id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "The proxy allocates a stable synthetic default variant GID for staged productCreate."
      },
      {
        "path": "$.productCreate.product.variants.nodes[0].inventoryItem.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "The proxy allocates a stable synthetic inventory item GID for the staged default variant."
      },
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The downstream proxy read uses the staged synthetic product GID."
      },
      {
        "path": "$.product.variants.nodes[0].id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "The downstream proxy read uses the staged synthetic default variant GID."
      },
      {
        "path": "$.product.variants.nodes[0].inventoryItem.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "The downstream proxy read uses the staged synthetic inventory item GID."
      },
      {
        "path": "$.variant.id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "Top-level productVariant reads address the staged synthetic variant ID."
      },
      {
        "path": "$.variant.inventoryItem.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "Top-level productVariant reads expose the staged synthetic inventory item ID."
      },
      {
        "path": "$.variant.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "Variant backreferences point at the staged synthetic product ID."
      },
      {
        "path": "$.stock.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "Top-level inventoryItem reads address the staged synthetic inventory item ID."
      },
      {
        "path": "$.stock.variant.id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "Inventory item backreferences point at the staged synthetic variant ID."
      },
      {
        "path": "$.stock.variant.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "Inventory item variant backreferences point at the staged synthetic product ID."
      }
    ],
    "targets": [
      {
        "name": "mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyPath": "$.data"
      },
      {
        "name": "downstream-inventory-read-data",
        "capturePath": "$.downstreamRead.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/productCreate-inventory-read-downstream.graphql",
          "variables": {
            "productId": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            },
            "variantId": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.variants.nodes[0].id"
            },
            "inventoryItemId": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.variants.nodes[0].inventoryItem.id"
            }
          }
        },
        "proxyPath": "$.data"
      }
    ]
  }
}
