{
  "scenarioId": "product-delete-async-operation",
  "operationNames": ["productSet", "productDelete", "productOperation", "product", "node"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "async-operation-parity", "downstream-read-parity", "user-errors-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/product-delete-async-operation.json"
  ],
  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/products_mutation_test.gleam", "test/parity_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productDelete-async-source-create.graphql",
    "variablesCapturePath": "$.setup.sourceCreate.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Captured async productDelete on a disposable product. Shopify returns a ProductDeleteOperation in CREATED status with null deletedProductId, leaves the product visible immediately after the mutation, resolves the operation through productOperation(id:) and node(id:), and rejects a second pending async delete with the public field/message UserError shape.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-source-create-data",
        "capturePath": "$.setup.sourceCreate.response.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productSet.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The local setup request mints a synthetic product GID while the capture created a disposable live product."
          }
        ]
      },
      {
        "name": "async-delete-mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDelete-async-operation.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.productSet.product.id"
              }
            },
            "synchronous": false
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productDelete.productDeleteOperation.id",
            "matcher": "shopify-gid:ProductDeleteOperation",
            "reason": "ProductDeleteOperation IDs are allocated independently by Shopify and the local staging identity registry."
          }
        ]
      },
      {
        "name": "duplicate-pending-mutation-data",
        "capturePath": "$.duplicateMutation.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDelete-async-operation.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.productSet.product.id"
              }
            },
            "synchronous": false
          }
        },
        "proxyPath": "$.data"
      },
      {
        "name": "immediate-product-read-data",
        "capturePath": "$.downstreamRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDelete-async-product-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productSet.product.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The downstream proxy read uses the local product GID from the replayed setup request."
          }
        ]
      },
      {
        "name": "operation-read-data",
        "capturePath": "$.operationRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDelete-operation-read.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "async-delete-mutation-data",
              "path": "$.data.productDelete.productDeleteOperation.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productOperation.id",
            "matcher": "shopify-gid:ProductDeleteOperation",
            "reason": "The downstream proxy read uses the stable local ProductDeleteOperation GID generated by the staged async productDelete response."
          },
          {
            "path": "$.productOperation.deletedProductId",
            "matcher": "shopify-gid:Product",
            "reason": "The completed local ProductDeleteOperation points at the replayed setup product GID."
          },
          {
            "path": "$.productOperation.status",
            "matcher": "any-string",
            "reason": "The live operation can advance between immediate helper reads; the local proxy exposes the completed operation deterministically on readback."
          }
        ]
      },
      {
        "name": "operation-node-read-data",
        "capturePath": "$.nodeRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDelete-operation-node-read.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "async-delete-mutation-data",
              "path": "$.data.productDelete.productDeleteOperation.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.node.id",
            "matcher": "shopify-gid:ProductDeleteOperation",
            "reason": "The downstream proxy node read uses the stable local ProductDeleteOperation GID generated by the staged async productDelete response."
          },
          {
            "path": "$.node.deletedProductId",
            "matcher": "shopify-gid:Product",
            "reason": "The completed local ProductDeleteOperation points at the replayed setup product GID."
          }
        ]
      }
    ]
  }
}
