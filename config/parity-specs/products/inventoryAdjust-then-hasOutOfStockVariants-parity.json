{
  "scenarioId": "inventory-adjust-then-has-out-of-stock-variants-parity",
  "operationNames": ["productSet", "inventoryAdjustQuantities"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/inventory-adjust-then-has-out-of-stock-variants-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/inventoryAdjust-then-hasOutOfStockVariants-setup.graphql",
    "variablesCapturePath": "$.setup.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "HAR-592 executable parity for product stock aggregates after an inventory quantity mutation. The scenario creates one tracked variant with available stock, adjusts it down to zero, and verifies the parent product's hasOutOfStockVariants and totalInventory fields through an immediate downstream read.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.productSet.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The proxy generates a stable local product GID while Shopify returns the disposable dev-store product GID."
      },
      {
        "path": "$.productSet.product.variants.nodes[0].id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "The proxy generates a stable local variant GID."
      },
      {
        "path": "$.productSet.product.variants.nodes[0].inventoryItem.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "The proxy generates a stable local inventory item GID."
      },
      {
        "path": "$.productSet.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].id",
        "matcher": "shopify-gid:InventoryLevel",
        "reason": "Inventory level IDs include independently allocated inventory item identifiers."
      },
      {
        "path": "$[0].item.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "Adjustment payloads reference the locally generated inventory item ID."
      },
      {
        "path": "$[1].item.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "Adjustment payloads reference the locally generated inventory item ID."
      },
      {
        "path": "$[0].location.name",
        "matcher": "any-string",
        "reason": "The proxy uses an empty location name when a location baseline is unavailable during local replay."
      },
      {
        "path": "$[1].location.name",
        "matcher": "any-string",
        "reason": "The proxy uses an empty location name when a location baseline is unavailable during local replay."
      },
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The downstream proxy read uses the local product GID generated by productSet."
      },
      {
        "path": "$.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].location.name",
        "matcher": "any-string",
        "reason": "The proxy uses an empty location name when a location baseline is unavailable during local replay."
      },
      {
        "path": "$.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].quantities[2]",
        "ignore": true,
        "regrettable": true,
        "reason": "The local productSet inventory helper retains an extra zero-valued incoming quantity row while this HAR-592 scenario asserts available/on_hand stock aggregates."
      }
    ],
    "targets": [
      {
        "name": "setup-stock-fields",
        "capturePath": "$.setup.response.data",
        "proxyPath": "$.data",
        "selectedPaths": [
          "$.productSet.product.totalVariants",
          "$.productSet.product.hasOnlyDefaultVariant",
          "$.productSet.product.hasOutOfStockVariants",
          "$.productSet.product.tracksInventory",
          "$.productSet.product.totalInventory",
          "$.productSet.userErrors"
        ]
      },
      {
        "name": "inventory-adjust-payload",
        "capturePath": "$.adjust.response.data",
        "proxyPath": "$.data",
        "selectedPaths": [
          "$.inventoryAdjustQuantities.inventoryAdjustmentGroup.reason",
          "$.inventoryAdjustQuantities.inventoryAdjustmentGroup.referenceDocumentUri",
          "$.inventoryAdjustQuantities.inventoryAdjustmentGroup.changes",
          "$.inventoryAdjustQuantities.userErrors"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventoryAdjust-then-hasOutOfStockVariants-adjust.graphql",
          "variables": {
            "input": {
              "name": "available",
              "reason": "correction",
              "referenceDocumentUri": {
                "fromCapturePath": "$.adjust.variables.input.referenceDocumentUri"
              },
              "changes": [
                {
                  "inventoryItemId": {
                    "fromPrimaryProxyPath": "$.data.productSet.product.variants.nodes[0].inventoryItem.id"
                  },
                  "locationId": {
                    "fromPrimaryProxyPath": "$.data.productSet.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].location.id"
                  },
                  "delta": -1
                }
              ]
            }
          }
        }
      },
      {
        "name": "downstream-stock-fields",
        "capturePath": "$.downstreamRead.data",
        "proxyPath": "$.data",
        "selectedPaths": [
          "$.product.totalVariants",
          "$.product.hasOnlyDefaultVariant",
          "$.product.hasOutOfStockVariants",
          "$.product.tracksInventory",
          "$.product.variants.nodes[0].inventoryQuantity",
          "$.product.variants.nodes[0].inventoryItem.tracked",
          "$.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].quantities[0]",
          "$.product.variants.nodes[0].inventoryItem.inventoryLevels.nodes[0].quantities[1]"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventoryAdjust-then-hasOutOfStockVariants-downstream.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productSet.product.id"
            }
          }
        }
      },
      {
        "name": "downstream-total-inventory",
        "capturePath": "$.downstreamRead.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventoryAdjust-then-hasOutOfStockVariants-downstream.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productSet.product.id"
            }
          }
        }
      }
    ]
  }
}
