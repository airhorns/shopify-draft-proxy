  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Executable parity for explicit `productOptionsCreate(variantStrategy: LEAVE_AS_IS)`: Shopify updates the standalone variant to the first new option value, keeps additional option values non-variant-backed, and returns no userErrors. Proxy replay first hydrates the captured pre-mutation product through a public product read, then runs the supported mutation locally.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.productOptionsCreate.product.options[0].id",
        "matcher": "shopify-gid:ProductOption",
        "reason": "Product option IDs are allocated independently by Shopify and the local staging identity registry."
      },
      {
        "path": "$.productOptionsCreate.product.options[0].optionValues[*].id",
        "matcher": "shopify-gid:ProductOptionValue",
        "reason": "Product option value IDs are allocated independently by Shopify and the local staging identity registry."
      },
      {
        "path": "$.product.options[0].id",
        "matcher": "shopify-gid:ProductOption",
        "reason": "The downstream proxy read returns the locally generated product option ID."
      },
      {
        "path": "$.product.options[0].optionValues[*].id",
        "matcher": "shopify-gid:ProductOptionValue",
        "reason": "The downstream proxy read returns locally generated product option value IDs."
      }
    ],
    "targets": [
