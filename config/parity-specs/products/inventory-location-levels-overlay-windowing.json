      {
        "name": "location-inventory-levels-overlay-read",
        "capturePath": "$.operations.overlayRead.response.data",
        "proxyPath": "$.data",
        "preserveProxyState": true,
        "selectedPaths": [
          "$.location.inventoryLevels.nodes[*].item.id",
          "$.location.inventoryLevels.nodes[*].quantities",
          "$.location.inventoryLevels.pageInfo.hasNextPage",
          "$.location.inventoryLevels.pageInfo.hasPreviousPage",
          "$.location.firstPage.nodes[*].quantities",
          "$.location.firstPage.pageInfo.hasNextPage",
          "$.location.firstPage.pageInfo.hasPreviousPage",
          "$.location.filtered.nodes[*].item.id",
          "$.location.filtered.nodes[*].quantities",
          "$.location.filtered.pageInfo.hasNextPage",
          "$.location.filtered.pageInfo.hasPreviousPage"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-location-levels-read.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "locationId": {
              "fromPrimaryProxyPath": "$.data.locationAdd.location.id"
            },
            "inventoryItemQuery": {
              "fromProxyResponse": "product-set",
              "path": "$.data.productSet.product.variants.nodes[0].inventoryItem.id",
              "resourceIdTail": true,
              "prefix": "inventory_item_id:"
