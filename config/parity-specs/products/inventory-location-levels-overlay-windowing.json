                      "quantity": 0
                    }
                  ]
                },
                {
                  "optionValues": [{ "optionName": "Title", "name": "Beta" }],
                  "price": "11.00",
                  "sku": {
                    "fromCapturePath": "$.setup.skuBeta"
                  },
                  "inventoryItem": { "tracked": true, "requiresShipping": true },
                  "inventoryQuantities": [
                    {
                      "locationId": {
                        "fromPrimaryProxyPath": "$.data.locationAdd.location.id"
                      },
                      "name": "available",
                      "quantity": 0
                    }
                  ]
                }
              ]
            }
          }
        }
