          "$.productSetOperation",
          "$.userErrors"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-connection-product-set.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "synchronous": true,
            "input": {
              "title": {
                "fromCapturePath": "$.operations.productSet.variables.input.title"
