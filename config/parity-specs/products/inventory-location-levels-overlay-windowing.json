          }
        },
        "expectedDifferences": [
          {
            "path": "$.location.inventoryLevels.nodes[*].item.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "Live Shopify and the local draft proxy allocate different product-backed inventory item ids."
          },
          {
            "path": "$.location.filtered.nodes[*].item.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "Live Shopify and the local draft proxy allocate different product-backed inventory item ids."
          }
        ]
      },
      {
        "name": "inventory-item-level-read",
        "capturePath": "$.operations.itemRead.response.data",
