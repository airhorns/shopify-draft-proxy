        "preserveProxyState": true,
        "selectedPaths": [
          "$.inventoryAdjustmentGroup.reason",
          "$.inventoryAdjustmentGroup.changes[*].name",
          "$.inventoryAdjustmentGroup.changes[*].delta",
          "$.inventoryAdjustmentGroup.changes[*].location.name",
          "$.userErrors"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-location-levels-adjust.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "input": {
              "name": "available",
              "reason": "correction",
              "changes": [
                {
                  "inventoryItemId": {
                    "fromProxyResponse": "product-set",
                    "path": "$.data.productSet.product.variants.nodes[0].inventoryItem.id"
                  },
                  "locationId": {
                    "fromPrimaryProxyPath": "$.data.locationAdd.location.id"
                  },
