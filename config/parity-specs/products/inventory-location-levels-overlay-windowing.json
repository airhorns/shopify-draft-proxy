          }
        },
        "expectedDifferences": [
          {
            "path": "$.firstItem.inventoryLevel.item.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "Live Shopify and the local draft proxy allocate different product-backed inventory item ids."
          }
        ]
      },
      {
        "name": "location-inventory-levels-window",
        "capturePath": "$.operations.windowRead.response.data",
        "proxyPath": "$.data",
        "preserveProxyState": true,
        "selectedPaths": [
          "$.location.afterFirst.nodes[*].quantities",
          "$.location.afterFirst.pageInfo.hasNextPage",
          "$.location.afterFirst.pageInfo.hasPreviousPage",
          "$.location.beforeSecond.nodes[*].quantities",
          "$.location.beforeSecond.pageInfo.hasNextPage",
          "$.location.beforeSecond.pageInfo.hasPreviousPage"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-location-levels-window.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "locationId": {
              "fromPrimaryProxyPath": "$.data.locationAdd.location.id"
            },
            "after": {
              "fromProxyResponse": "location-inventory-levels-overlay-read",
              "path": "$.data.location.inventoryLevels.edges[0].cursor"
            },
            "before": {
              "fromProxyResponse": "location-inventory-levels-overlay-read",
              "path": "$.data.location.inventoryLevels.edges[1].cursor"
            }
          }
        }
      }
    ]
  },
  "notes": "Captured Admin GraphQL 2025-01 evidence that Location.inventoryLevels reflects inventorySetQuantities plus inventoryAdjustQuantities, agrees with inventoryItem.inventoryLevel(locationId:), honors inventory_item_id query filtering, and returns Shopify-style cursor windows."
