  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Executable compatibility parity for `productVariantCreate`: the proxy first creates the product through the normal GraphQL productCreate path, then runs the checked-in single-variant legacy create request and compares it against the equivalent live-supported `productVariantsBulkCreate` capture with explicit strict-json targets for payload shape, user errors, inventory summary, and downstream product reads. Linear HAR-189 tracks re-checking direct legacy-root availability on future Shopify schemas; this spec is no longer capture-only or pending Markdown evidence.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-product-user-errors",
        "capturePath": "$.mutation.response.data.productVariantsBulkCreate.userErrors",
        "proxyPath": "$.data.productCreate.userErrors"
      },
      {
        "name": "variant-payload",
        "capturePath": "$.mutation.response.data.productVariantsBulkCreate.productVariants[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantCreate-parity-plan.graphql",
          "variables": {
            "input": {
              "productId": {
                "fromPrimaryProxyPath": "$.data.productCreate.product.id"
              },
              "title": "Blue",
              "sku": {
                "fromCapturePath": "$.mutation.variables.variants[0].inventoryItem.sku"
              },
              "barcode": "2222222222222",
              "price": "26.00",
              "compareAtPrice": "30.00",
              "taxable": false,
              "taxCode": "P0000000",
              "requiresComponents": true,
              "showUnitPrice": true,
              "unitPriceMeasurement": {
                "quantityValue": 2.5,
                "quantityUnit": "L",
                "referenceValue": 1,
                "referenceUnit": "L"
              },
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Blue"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": false,
                "countryCodeOfOrigin": "US",
                "provinceCodeOfOrigin": "CA",
                "harmonizedSystemCode": "1234.56",
                "measurement": {
                  "weight": {
                    "value": 0.25,
                    "unit": "KILOGRAMS"
                  }
                }
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantCreate.productVariant",
        "excludedPaths": ["$.position"],
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The proxy allocates a stable synthetic product variant GID for the staged compatibility wrapper; Shopify returns the dev-store variant GID from the bulk-create capture."
