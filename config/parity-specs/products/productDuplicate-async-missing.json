{
  "scenarioId": "product-duplicate-async-missing",
  "operationNames": ["productDuplicate", "productOperation"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/product-duplicate-async-missing.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productDuplicate-async.graphql",
    "variablesCapturePath": "$.mutation.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Captured async productDuplicate for a missing product. Shopify creates a ProductDuplicateOperation in the mutation payload with empty userErrors, then exposes the missing-product userError through productOperation(id:) once the operation completes.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productDuplicate.productDuplicateOperation.id",
            "matcher": "shopify-gid:ProductDuplicateOperation",
            "reason": "ProductDuplicateOperation IDs are allocated independently by Shopify and the local staging identity registry."
          }
        ]
      },
      {
        "name": "operation-read-data",
        "capturePath": "$.operationRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productDuplicate-operation-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productDuplicate.productDuplicateOperation.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productOperation.id",
            "matcher": "shopify-gid:ProductDuplicateOperation",
            "reason": "The downstream proxy read uses the stable local ProductDuplicateOperation GID generated by the staged async productDuplicate response."
          }
        ]
      }
    ]
  }
}
