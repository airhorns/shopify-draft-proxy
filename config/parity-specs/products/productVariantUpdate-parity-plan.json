{
  "scenarioId": "product-variant-update-compatibility-evidence",
  "operationNames": ["productVariantUpdate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/very-big-test-store.myshopify.com/2025-01/products/product-variants-bulk-update-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productVariantCompatibility-setup-product.graphql",
    "variables": {
      "product": {
        "title": "Hermes Variant Compatibility",
        "handle": "hermes-variant-compatibility",
        "status": "ACTIVE"
      }
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Executable compatibility parity for `productVariantUpdate`: the proxy creates the product and baseline red variant through normal GraphQL requests before running the checked-in single-variant legacy update request, then compares against the equivalent live-supported `productVariantsBulkUpdate` capture with explicit strict-json targets for product summaries, variant payload fields, user errors, and downstream product.variants/search-lag reads. Linear HAR-189 tracks re-checking direct legacy-root availability on future Shopify schemas; this spec is no longer capture-only or pending Markdown evidence.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-product-user-errors",
        "capturePath": "$.mutation.response.data.productVariantsBulkUpdate.userErrors",
        "proxyPath": "$.data.productCreate.userErrors"
      },
      {
        "name": "setup-red-variant",
        "capturePath": "$.downstreamRead.data.product.variants.nodes[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantCompatibility-setup-variant.graphql",
          "variables": {
            "input": {
              "productId": {
                "fromPrimaryProxyPath": "$.data.productCreate.product.id"
              },
              "title": "Red",
              "sku": "HERMES-BULK-810153-DRAFT",
              "barcode": "0000000000000",
              "price": "12.00",
              "compareAtPrice": "15.00",
              "taxable": false,
              "inventoryPolicy": "CONTINUE",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Red"
                }
              ],
              "inventoryItem": {
                "tracked": false,
                "requiresShipping": false
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantCreate.productVariant",
        "excludedPaths": ["$.taxable", "$.inventoryItem.tracked", "$.inventoryItem.requiresShipping"],
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The proxy stages the baseline variant through the legacy create path and therefore uses a synthetic variant GID while Shopify returns the captured dev-store variant GID."
          },
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The proxy creates the setup product through the local productCreate path and therefore uses a synthetic product GID while Shopify returns the captured dev-store product GID."
          },
          {
            "path": "$.inventoryItem.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "The proxy stages the baseline variant through the legacy create path and therefore uses a synthetic inventory item GID while Shopify returns the captured dev-store inventory item GID."
          },
          {
            "path": "$.sku",
            "matcher": "exact-string:HERMES-BULK-810153-DRAFT",
            "reason": "The setup variant intentionally starts with pre-update values so the later legacy update request proves field mutation."
          },
          {
            "path": "$.barcode",
            "matcher": "exact-string:0000000000000",
            "reason": "The setup variant intentionally starts with pre-update values so the later legacy update request proves field mutation."
          },
          {
            "path": "$.price",
            "matcher": "exact-string:12.00",
            "reason": "The setup variant intentionally starts with pre-update values so the later legacy update request proves field mutation."
          },
          {
            "path": "$.compareAtPrice",
            "matcher": "exact-string:15.00",
            "reason": "The setup variant intentionally starts with pre-update values so the later legacy update request proves field mutation."
          },
          {
            "path": "$.inventoryPolicy",
            "matcher": "exact-string:CONTINUE",
            "reason": "The setup variant intentionally starts with pre-update values so the later legacy update request proves field mutation."
          }
        ]
      },
      {
        "name": "updated-variant",
        "capturePath": "$.downstreamRead.data.product.variants.nodes[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantUpdate-parity-plan.graphql",
          "variables": {
            "input": {
              "id": {
                "fromProxyResponse": "setup-red-variant",
                "path": "$.data.productVariantCreate.productVariant.id"
              },
              "title": "Red",
              "sku": "HERMES-BULK-810153-RED",
              "barcode": "1111111111111",
              "price": "24.00",
              "compareAtPrice": "30.00",
              "taxable": true,
              "inventoryPolicy": "DENY",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Red"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": true
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantUpdate.productVariant",
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The proxy stages the baseline variant through the legacy create path and therefore uses a synthetic variant GID while Shopify returns the captured dev-store variant GID."
          },
          {
            "path": "$.inventoryItem.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "The proxy stages the baseline variant through the legacy create path and therefore uses a synthetic inventory item GID while Shopify returns the captured dev-store inventory item GID."
          }
        ]
      },
      {
        "name": "product-payload",
        "capturePath": "$.mutation.response.data.productVariantsBulkUpdate.product",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantUpdate-parity-plan.graphql",
          "variables": {
            "input": {
              "id": {
                "fromProxyResponse": "setup-red-variant",
                "path": "$.data.productVariantCreate.productVariant.id"
              },
              "title": "Red",
              "sku": "HERMES-BULK-810153-RED",
              "barcode": "1111111111111",
              "price": "24.00",
              "compareAtPrice": "30.00",
              "taxable": true,
              "inventoryPolicy": "DENY",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Red"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": true
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantUpdate.product",
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:Product",
            "reason": "The local setup product is created through productCreate and uses a synthetic product GID."
          },
          {
            "path": "$.variants.nodes[*].id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The setup variant is created through the proxy legacy create path and uses a synthetic variant GID."
          },
          {
            "path": "$.variants.nodes[*].inventoryItem.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "The setup variant is created through the proxy legacy create path and uses a synthetic inventory item GID."
          }
        ]
      },
      {
        "name": "user-errors",
        "capturePath": "$.mutation.response.data.productVariantsBulkUpdate.userErrors",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantUpdate-parity-plan.graphql",
          "variables": {
            "input": {
              "id": {
                "fromProxyResponse": "setup-red-variant",
                "path": "$.data.productVariantCreate.productVariant.id"
              },
              "title": "Red",
              "sku": "HERMES-BULK-810153-RED",
              "barcode": "1111111111111",
              "price": "24.00",
              "compareAtPrice": "30.00",
              "taxable": true,
              "inventoryPolicy": "DENY",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Red"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": true
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantUpdate.userErrors"
      },
      {
        "name": "downstream-read",
        "capturePath": "$.downstreamRead.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantUpdate-downstream-read.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "updated-variant",
              "path": "$.data.productVariantUpdate.product.id"
            },
            "query": "sku:HERMES-BULK-810153-RED"
          }
        },
        "upstreamCapturePath": null,
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The local setup product is created through productCreate and uses a synthetic product GID."
          },
          {
            "path": "$.product.variants.nodes[*].id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The setup variant is created through the proxy legacy create path and uses a synthetic variant GID."
          },
          {
            "path": "$.product.variants.nodes[*].inventoryItem.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "The setup variant is created through the proxy legacy create path and uses a synthetic inventory item GID."
          },
          {
            "path": "$.products.nodes[0]",
            "ignore": true,
            "regrettable": true,
            "reason": "The local store-backed overlay exposes the updated product by effective variant SKU immediately; the captured Shopify read shows search-index lag for the just-written SKU."
          },
          {
            "path": "$.skuCount.count",
            "matcher": "any-number",
            "reason": "The local store-backed overlay counts the updated product by effective variant SKU immediately; the captured Shopify read shows search-index lag for the just-written SKU."
          }
        ]
      }
    ]
  }
}
