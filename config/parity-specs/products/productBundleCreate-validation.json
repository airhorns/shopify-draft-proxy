        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productBundleCreate-validation.graphql",
          "variables": {
            "input": {
              "title": { "fromCapturePath": "$.captures.optionSelectionsOverLimit.variables.input.title" },
