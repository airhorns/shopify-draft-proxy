        "expectedDifferences": [
          {
            "path": "$.userErrors[0].message",
            "matcher": "regex:^Mapping of components targeting products need to map all of the options of the product.",
            "reason": "The replay uses a proxy-created product id, so the product id embedded in Shopify's validation message is intentionally not compared exactly."
