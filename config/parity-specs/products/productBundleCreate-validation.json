                      "name": "Color",
                      "values": ["Red"]
                    },
                    {
                      "componentOptionId": { "fromPrimaryProxyPath": "$.data.productCreate.product.options[1].id" },
                      "name": "Size",
                      "values": ["Small"]
                    },
