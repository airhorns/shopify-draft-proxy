    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The live fixture uses Shopify product IDs while the proxy allocates deterministic synthetic product IDs."
      },
      {
        "path": "$.product.options[*].id",
        "matcher": "shopify-gid:ProductOption",
        "reason": "Product option IDs are generated independently by Shopify and by the proxy."
      },
      {
        "path": "$.product.options[*].optionValues[*].id",
        "matcher": "shopify-gid:ProductOptionValue",
        "reason": "Product option value IDs are generated independently by Shopify and by the proxy."
      },
      {
        "path": "$.product.variants.nodes[*].id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "Product variant IDs are generated independently by Shopify and by the proxy."
      },
      {
        "path": "$.productVariants[*].id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "Setup variant IDs are generated independently by Shopify and by the proxy."
      }
