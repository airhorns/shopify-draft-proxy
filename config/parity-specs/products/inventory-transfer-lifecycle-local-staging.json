{
  "scenarioId": "inventory-transfer-lifecycle-local-staging",
  "operationNames": [
    "inventoryTransfer",
    "inventoryTransfers",
    "inventoryTransferCreate",
    "inventoryTransferEdit",
    "inventoryTransferSetItems",
    "inventoryTransferDuplicate",
    "inventoryTransferMarkAsReadyToShip",
    "inventoryTransferCancel",
    "inventoryTransferDelete"
  ],
  "scenarioStatus": "captured",
  "assertionKinds": [
    "runtime-staging",
    "empty-state-parity",
    "downstream-read-parity",
    "inventory-quantity-side-effect",
    "no-upstream-passthrough"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/inventory-transfer-create.graphql",
    "variablesCapturePath": "$.workflow.createDraft.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "draft-create-mutation-data",
        "capturePath": "$.draftCreate.data.inventoryTransferCreate",
        "proxyPath": "$.data.inventoryTransferCreate",
        "excludedPaths": ["$.inventoryTransfer.id"],
        "expectedDifferences": [
          {
            "path": "$.inventoryTransfer.name",
            "matcher": "non-empty-string",
            "reason": "Transfer names are assigned by Shopify in the live store and by the local proxy's deterministic synthetic sequence during parity replay."
          }
        ]
      },
      {
        "name": "draft-edit-mutation-data",
        "capturePath": "$.draftEdit.data.inventoryTransferEdit",
        "proxyPath": "$.data.inventoryTransferEdit",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-edit.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
            },
            "input": {
              "originId": {
                "fromCapturePath": "$.setup.originLocation.id"
              },
              "destinationId": {
                "fromCapturePath": "$.setup.destinationLocation.id"
              },
              "note": "inventory transfer conformance edited",
              "tags": ["inventory-transfer-conformance", "edited"],
              "referenceName": {
                "fromCapturePath": "$.workflow.editDraft.variables.input.referenceName"
              }
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.inventoryTransfer.id",
            "matcher": "shopify-gid:InventoryTransfer",
            "reason": "The local proxy keeps the synthetic transfer ID from the primary draft create."
          },
          {
            "path": "$.inventoryTransfer.name",
            "matcher": "non-empty-string",
            "reason": "Transfer names are assigned by Shopify in the live store and by the local proxy's deterministic synthetic sequence during parity replay."
          },
          {
            "path": "$.inventoryTransfer.lineItems.nodes[*].id",
            "matcher": "shopify-gid:InventoryTransferLineItem",
            "reason": "The local proxy generates stable session-local transfer line item IDs."
          }
        ]
      },
      {
        "name": "draft-set-items-mutation-data",
        "capturePath": "$.draftSetItems.data.inventoryTransferSetItems",
        "proxyPath": "$.data.inventoryTransferSetItems",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-set-items.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
              },
              "lineItems": [
                {
                  "inventoryItemId": {
                    "fromCapturePath": "$.setup.inventoryItemId"
                  },
                  "quantity": 3
                }
              ]
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.inventoryTransfer.id",
            "matcher": "shopify-gid:InventoryTransfer",
            "reason": "The local proxy keeps the synthetic transfer ID from the primary draft create."
          },
          {
            "path": "$.inventoryTransfer.lineItems.nodes[*].id",
            "matcher": "shopify-gid:InventoryTransferLineItem",
            "reason": "The local proxy generates stable session-local transfer line item IDs."
          }
        ]
      },
      {
        "name": "draft-duplicate-mutation-data",
        "capturePath": "$.draftDuplicate.data.inventoryTransferDuplicate",
        "proxyPath": "$.data.inventoryTransferDuplicate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-duplicate.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.inventoryTransfer.id",
            "matcher": "shopify-gid:InventoryTransfer",
            "reason": "The local proxy generates a new synthetic transfer ID for the duplicate."
          },
          {
            "path": "$.inventoryTransfer.name",
            "matcher": "non-empty-string",
            "reason": "Transfer names are assigned by Shopify in the live store and by the local proxy's deterministic synthetic sequence during parity replay."
          },
          {
            "path": "$.inventoryTransfer.lineItems.nodes[*].id",
            "matcher": "shopify-gid:InventoryTransferLineItem",
            "reason": "The local proxy generates stable session-local transfer line item IDs."
          }
        ]
      },
      {
        "name": "mark-ready-mutation-data",
        "capturePath": "$.readyTransition.data.inventoryTransferMarkAsReadyToShip",
        "proxyPath": "$.data.inventoryTransferMarkAsReadyToShip",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-mark-ready.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
            }
          }
        }
      },
      {
        "name": "after-ready-inventory-read",
        "capturePath": "$.readyInventoryReadAfterWriteGraphql.data.inventoryItem",
        "proxyPath": "$.data.inventoryItem",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-inventory-read-all-levels.graphql",
          "variablesCapturePath": "$.workflow.afterReadyInventoryRead.variables"
        }
      },
      {
        "name": "cancel-ready-transfer",
        "capturePath": "$.cancelReadyTransfer.data.inventoryTransferCancel",
        "proxyPath": "$.data.inventoryTransferCancel",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-cancel.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
            }
          }
        }
      },
      {
        "name": "delete-non-draft-guardrail",
        "capturePath": "$.deleteNonDraftGuardrail.data.inventoryTransferDelete",
        "proxyPath": "$.data.inventoryTransferDelete",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-transfer-delete.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryTransferCreate.inventoryTransfer.id"
            }
          }
        }
      }
    ]
  },
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/inventory-transfer-lifecycle-local-staging.json"
  ],
  "runtimeTestFiles": ["tests/integration/inventory-transfer-flow.test.ts"],
  "notes": "Replays the captured Shopify draft create, draft edit, draft set-items, draft duplicate, ready transition, downstream inventory reservation read, cancel transition, and non-draft delete guardrail through the local proxy harness. The scenario earns its local product-backed inventory item and origin/destination inventory levels through captured upstream hydration before replay, while the runtime test continues to cover remove/delete draft branches, empty reads, validation guardrails, raw log ordering, and no runtime Shopify writes."
}
