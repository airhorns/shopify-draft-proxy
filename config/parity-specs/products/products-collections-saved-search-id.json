          }
        },
        "expectedDifferences": [
          {
            "path": "$.productsDirect.nodes[*].id",
            "matcher": "shopify-gid:Product",
            "reason": "The live and local read target equivalent but independently allocated products."
          },
          {
            "path": "$.productsSaved.nodes[*].id",
            "matcher": "shopify-gid:Product",
            "reason": "The live and local read target equivalent but independently allocated products."
          },
          {
            "path": "$.collectionsDirect.nodes[*].id",
            "matcher": "shopify-gid:Collection",
            "reason": "The live and local read target equivalent but independently allocated collections."
          },
          {
            "path": "$.collectionsSaved.nodes[*].id",
            "matcher": "shopify-gid:Collection",
            "reason": "The live and local read target equivalent but independently allocated collections."
          }
        ]
      },
