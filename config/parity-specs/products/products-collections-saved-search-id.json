  "notes": "Live Shopify capture for products(savedSearchId:), productsCount(savedSearchId:), collections(savedSearchId:), and collectionsCount(savedSearchId:) resolving a saved search's stored query. The replay creates disposable product and collection records through public mutations, creates product and collection saved searches using the proxy-allocated resource IDs, then compares direct query reads against savedSearchId reads plus Shopify's unknown-id and query-plus-savedSearchId resolver errors.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "product-create-setup",
        "capturePath": "$.operations.productCreate.response.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productCreate.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "Shopify and the local proxy allocate product identifiers independently."
          }
        ]
      },
      {
        "name": "collection-create-setup",
        "capturePath": "$.operations.collectionCreate.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/saved-search-id-collection-create.graphql",
          "variablesCapturePath": "$.operations.collectionCreate.request.variables"
        },
        "expectedDifferences": [
          {
            "path": "$.collectionCreate.collection.id",
            "matcher": "shopify-gid:Collection",
            "reason": "Shopify and the local proxy allocate collection identifiers independently."
          }
        ]
      },
      {
        "name": "product-saved-search-create",
        "capturePath": "$.operations.productSavedSearchCreate.response.data.savedSearchCreate",
        "proxyPath": "$.data.savedSearchCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/saved-search-id-saved-search-create.graphql",
          "variables": {
            "input": {
              "name": {
                "fromCapturePath": "$.operations.productSavedSearchCreate.request.variables.input.name"
              },
              "query": {
                "fromProxyResponse": "product-create-setup",
                "path": "$.data.productCreate.product.id",
                "resourceIdTail": true,
                "prefix": "id:"
              },
              "resourceType": "PRODUCT"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.savedSearch.id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "Shopify and the local proxy allocate saved-search identifiers independently."
          },
          {
            "path": "$.savedSearch.query",
            "matcher": "any-string",
            "reason": "The saved-search query intentionally targets the product ID allocated by the current runtime."
          }
        ]
      },
      {
        "name": "collection-saved-search-create",
        "capturePath": "$.operations.collectionSavedSearchCreate.response.data.savedSearchCreate",
        "proxyPath": "$.data.savedSearchCreate",
        "proxyRequest": {
