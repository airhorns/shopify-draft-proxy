              "resourceType": "COLLECTION"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.savedSearch.id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "Shopify and the local proxy allocate saved-search identifiers independently."
          },
          {
            "path": "$.savedSearch.query",
            "matcher": "any-string",
            "reason": "The saved-search query intentionally targets the collection ID allocated by the current runtime."
          }
        ]
      },
      {
        "name": "saved-search-id-read",
        "capturePath": "$.operations.validRead.response.data",
        "proxyPath": "$.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/saved-search-id-read.graphql",
