        "name": "create-in-transit",
        "capturePath": "$.workflow.createInTransit.response.payload.data.inventoryShipmentCreateInTransit",
        "proxyPath": "$.data.inventoryShipmentCreateInTransit",
        "expectedDifferences": [
          {
            "path": "$.inventoryShipment.id",
            "matcher": "shopify-gid:InventoryShipment",
            "reason": "The local proxy generates stable session-local shipment IDs."
          },
          {
            "path": "$.inventoryShipment.lineItems.nodes[*].id",
            "matcher": "shopify-gid:InventoryShipmentLineItem",
            "reason": "The local proxy generates stable session-local shipment line item IDs."
          }
        ]
      },
      {
        "name": "receive-partial",
        "capturePath": "$.workflow.receivePartial.response.payload.data.inventoryShipmentReceive",
