        "proxyRequest": {
          "documentPath": "config/parity-requests/products/inventory-shipment-receive.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.inventoryShipmentCreateInTransit.inventoryShipment.id"
            },
            "lineItems": [
              {
                "shipmentLineItemId": {
                  "fromPrimaryProxyPath": "$.data.inventoryShipmentCreateInTransit.inventoryShipment.lineItems.nodes[0].id"
                },
                "quantity": 3,
                "reason": "ACCEPTED"
              }
            ]
          }
        },
        "expectedDifferences": [
          {
            "path": "$.inventoryShipment.id",
            "matcher": "shopify-gid:InventoryShipment",
            "reason": "The local proxy keeps the synthetic shipment ID from the primary request."
          },
          {
            "path": "$.inventoryShipment.lineItems.nodes[*].id",
            "matcher": "shopify-gid:InventoryShipmentLineItem",
            "reason": "The local proxy keeps the synthetic shipment line item ID from the primary request."
          }
        ]
      },
      {
