{
  "scenarioId": "product-variant-delete-compatibility-evidence",
  "operationNames": ["productVariantDelete"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/very-big-test-store.myshopify.com/2025-01/products/product-variants-bulk-delete-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productVariantCompatibility-setup-product.graphql",
    "variables": {
      "product": {
        "title": "Hermes Variant Compatibility",
        "handle": "hermes-variant-compatibility",
        "status": "ACTIVE"
      }
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Executable compatibility parity for `productVariantDelete`: the proxy creates the product plus red/blue variants through normal GraphQL requests before running the checked-in single-variant legacy delete request, then compares against the equivalent live-supported `productVariantsBulkDelete` capture with explicit strict-json targets for the deleted variant id, user errors, and downstream product.variants/search-lag reads. Linear HAR-189 tracks re-checking direct legacy-root availability on future Shopify schemas; this spec is no longer capture-only or pending Markdown evidence.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.id",
        "matcher": "shopify-gid:ProductVariant",
        "reason": "The proxy stages setup variants through the legacy create path and therefore uses synthetic variant GIDs while Shopify returns captured dev-store variant GIDs."
      },
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The proxy creates the setup product through the local productCreate path and therefore uses a synthetic product GID while Shopify returns the captured dev-store product GID."
      },
      {
        "path": "$.inventoryItem.id",
        "matcher": "shopify-gid:InventoryItem",
        "reason": "The proxy stages setup variants through the legacy create path and therefore uses synthetic inventory item GIDs while Shopify returns captured dev-store inventory item GIDs."
      }
    ],
    "targets": [
      {
        "name": "setup-product-user-errors",
        "capturePath": "$.mutation.response.data.productVariantsBulkDelete.userErrors",
        "proxyPath": "$.data.productCreate.userErrors"
      },
      {
        "name": "setup-red-variant",
        "capturePath": "$.mutation.variables.variantsIds[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantCompatibility-setup-variant.graphql",
          "variables": {
            "input": {
              "productId": {
                "fromPrimaryProxyPath": "$.data.productCreate.product.id"
              },
              "title": "Red",
              "sku": "HERMES-BULK-810153-RED",
              "barcode": "1111111111111",
              "price": "24.00",
              "compareAtPrice": "30.00",
              "taxable": true,
              "inventoryPolicy": "DENY",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Red"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": true
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantCreate.productVariant.id",
        "expectedDifferences": [
          {
            "path": "$",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The setup variant is created through the proxy legacy create path and uses a synthetic variant GID."
          }
        ]
      },
      {
        "name": "setup-blue-variant",
        "capturePath": "$.downstreamRead.data.product.variants.nodes[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantCompatibility-setup-variant.graphql",
          "variables": {
            "input": {
              "productId": {
                "fromPrimaryProxyPath": "$.data.productCreate.product.id"
              },
              "title": "Blue",
              "sku": "HERMES-BULK-810153-BLUE",
              "barcode": "2222222222222",
              "price": "26.00",
              "compareAtPrice": "30.00",
              "taxable": true,
              "inventoryPolicy": "DENY",
              "inventoryQuantity": 0,
              "selectedOptions": [
                {
                  "name": "Color",
                  "value": "Blue"
                }
              ],
              "inventoryItem": {
                "tracked": true,
                "requiresShipping": false
              }
            }
          }
        },
        "proxyPath": "$.data.productVariantCreate.productVariant"
      },
      {
        "name": "deleted-variant-id",
        "capturePath": "$.mutation.variables.variantsIds[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantDelete-parity-plan.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "setup-red-variant",
              "path": "$.data.productVariantCreate.productVariant.id"
            }
          }
        },
        "proxyPath": "$.data.productVariantDelete.deletedProductVariantId",
        "expectedDifferences": [
          {
            "path": "$",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The deleted variant was created through the proxy legacy create path and uses a synthetic variant GID."
          }
        ]
      },
      {
        "name": "downstream-read",
        "capturePath": "$.downstreamRead.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productVariantsBulkDelete-downstream-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            },
            "query": "sku:HERMES-BULK-810153-RED"
          }
        },
        "upstreamCapturePath": null,
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The local setup product is created through productCreate and uses a synthetic product GID."
          },
          {
            "path": "$.product.variants.nodes[*].id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "The remaining setup variant is created through the proxy legacy create path and uses a synthetic variant GID."
          },
          {
            "path": "$.product.variants.nodes[*].inventoryItem.id",
            "matcher": "shopify-gid:InventoryItem",
            "reason": "The remaining setup variant is created through the proxy legacy create path and uses a synthetic inventory item GID."
          }
        ]
      }
    ]
  }
}
