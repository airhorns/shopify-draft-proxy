{
  "scenarioId": "product-update-media-ready-url-parity",
  "operationNames": ["productCreateMedia", "productUpdateMedia"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/product-update-media-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productCreateMedia-parity-plan.graphql",
    "apiVersion": "2025-01",
    "variablesCapturePath": "$.setup.createMedia.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Replays the live product media capture as a local staged create followed by productUpdateMedia. The exact targets prove READY media URL payload/readback shape while requiring the proxy to derive a deterministic per-media local URL instead of reusing a captured Shopify CDN URL.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "setup-create-media-data",
        "capturePath": "$.setup.createMedia.response.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productCreateMedia.media[0].id",
            "matcher": "shopify-gid:MediaImage",
            "reason": "The proxy generates a local MediaImage GID for the staged media create; Shopify returns the dev-store MediaImage GID."
          },
          {
            "path": "$.productCreateMedia.product.media.nodes[0].id",
            "matcher": "shopify-gid:MediaImage",
            "reason": "The product media connection reuses the staged local MediaImage GID generated by productCreateMedia."
          }
        ]
      },
      {
        "name": "ready-update-media-data",
        "capturePath": "$.mutation.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productUpdateMedia-parity-plan.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "productId": {
              "fromPrimaryProxyPath": "$.data.productCreateMedia.product.id"
            },
            "media": [
              {
                "id": {
                  "fromPrimaryProxyPath": "$.data.productCreateMedia.media[0].id"
                },
                "alt": {
                  "fromCapturePath": "$.mutation.variables.media[0].alt"
                }
              }
            ]
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productUpdateMedia.media[0].id",
            "matcher": "shopify-gid:MediaImage",
            "reason": "The update targets the proxy-generated staged MediaImage GID."
          },
          {
            "path": "$.productUpdateMedia.media[0].preview.image.url",
            "matcher": "regex:^https://shopify-draft-proxy\\.local/media/mediaimage-[A-Za-z0-9_-]+\\.png$",
            "reason": "Shopify returns a store-specific CDN URL; the proxy must derive a stable per-media local READY URL from staged media state."
          },
          {
            "path": "$.productUpdateMedia.media[0].image.url",
            "matcher": "regex:^https://shopify-draft-proxy\\.local/media/mediaimage-[A-Za-z0-9_-]+\\.png$",
            "reason": "Shopify returns a store-specific CDN URL; the proxy must derive a stable per-media local READY URL from staged media state."
          }
        ]
      },
      {
        "name": "ready-downstream-media-node",
        "capturePath": "$.downstreamRead.data.product.media.nodes[0]",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productUpdateMedia-downstream-read.graphql",
          "apiVersion": "2025-01",
          "variables": {
            "productId": {
              "fromPrimaryProxyPath": "$.data.productCreateMedia.product.id"
            }
          }
        },
        "proxyPath": "$.data.product.media.nodes[0]",
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:MediaImage",
            "reason": "The downstream read returns the proxy-generated staged MediaImage GID."
          },
          {
            "path": "$.preview.image.url",
            "matcher": "regex:^https://shopify-draft-proxy\\.local/media/mediaimage-[A-Za-z0-9_-]+\\.png$",
            "reason": "The downstream staged media read exposes the stable local READY URL rather than Shopify's store-specific CDN URL."
          },
          {
            "path": "$.image.url",
            "matcher": "regex:^https://shopify-draft-proxy\\.local/media/mediaimage-[A-Za-z0-9_-]+\\.png$",
            "reason": "The downstream staged media read exposes the stable local READY URL rather than Shopify's store-specific CDN URL."
          }
        ]
      }
    ]
  }
}
