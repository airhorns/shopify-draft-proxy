{
  "scenarioId": "product-create-then-bulk-create-price-range-parity",
  "operationNames": ["productCreate", "productVariantsBulkUpdate", "productVariantsBulkCreate"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/products/product-create-then-bulk-create-price-range-parity.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/products/productCreate-then-bulkCreate-derived-create.graphql",
    "variablesCapturePath": "$.create.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "HAR-592 executable parity for product-level derived fields after `productVariantsBulkCreate`. The live Shopify schema does not accept variants on `ProductCreateInput`, so this scenario creates the option-backed product, sets the initial Red variant price to 10.00 with `productVariantsBulkUpdate`, bulk-creates Blue and Green variants at 5.00 and 20.00, then verifies immediate product aggregate reads.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [
      {
        "path": "$.productVariantsBulkCreate.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The proxy generates a stable local product GID while Shopify returns the disposable dev-store product GID."
      },
      {
        "path": "$.product.id",
        "matcher": "shopify-gid:Product",
        "reason": "The downstream proxy read uses the local product GID generated by the staged create."
      },
      {
        "path": "$.minVariantPrice.amount",
        "matcher": "any-string",
        "reason": "The proxy intentionally emits two-decimal money strings for HAR-592 while Shopify trims trailing zeroes in MoneyV2 amount serialization."
      },
      {
        "path": "$.maxVariantPrice.amount",
        "matcher": "any-string",
        "reason": "The proxy intentionally emits two-decimal money strings for HAR-592 while Shopify trims trailing zeroes in MoneyV2 amount serialization."
      },
      {
        "path": "$.minVariantPrice.currencyCode",
        "matcher": "any-string",
        "reason": "The proxy has no shop baseline in this local-only mutation replay and falls back to USD; live Shopify returns the configured shop currency."
      },
      {
        "path": "$.maxVariantPrice.currencyCode",
        "matcher": "any-string",
        "reason": "The proxy has no shop baseline in this local-only mutation replay and falls back to USD; live Shopify returns the configured shop currency."
      }
    ],
    "targets": [
      {
        "name": "initial-price-update-user-errors",
        "capturePath": "$.priceUpdate.response.data.productVariantsBulkUpdate.userErrors",
        "proxyPath": "$.data.productVariantsBulkUpdate.userErrors",
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productCreate-then-bulkCreate-derived-price-update.graphql",
          "variables": {
            "productId": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            },
            "variants": [
              {
                "id": {
                  "fromPrimaryProxyPath": "$.data.productCreate.product.variants.nodes[0].id"
                },
                "price": "10.00"
              }
            ]
          }
        }
      },
      {
        "name": "bulk-create-derived-fields",
        "capturePath": "$.bulkCreate.response.data",
        "proxyPath": "$.data",
        "selectedPaths": [
          "$.productVariantsBulkCreate.product.priceRangeV2",
          "$.productVariantsBulkCreate.product.priceRange",
          "$.productVariantsBulkCreate.product.totalVariants",
          "$.productVariantsBulkCreate.product.hasOnlyDefaultVariant",
          "$.productVariantsBulkCreate.product.hasOutOfStockVariants",
          "$.productVariantsBulkCreate.product.tracksInventory",
          "$.productVariantsBulkCreate.product.totalInventory",
          "$.productVariantsBulkCreate.userErrors"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productCreate-then-bulkCreate-derived-bulk-create.graphql",
          "variables": {
            "productId": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            },
            "variants": [
              {
                "optionValues": [
                  {
                    "optionName": "Color",
                    "name": "Blue"
                  }
                ],
                "price": "5.00"
              },
              {
                "optionValues": [
                  {
                    "optionName": "Color",
                    "name": "Green"
                  }
                ],
                "price": "20.00"
              }
            ]
          }
        }
      },
      {
        "name": "downstream-derived-fields",
        "capturePath": "$.downstreamRead.data",
        "proxyPath": "$.data",
        "selectedPaths": [
          "$.product.priceRangeV2",
          "$.product.priceRange",
          "$.product.totalVariants",
          "$.product.hasOnlyDefaultVariant",
          "$.product.hasOutOfStockVariants",
          "$.product.tracksInventory",
          "$.product.totalInventory"
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/products/productCreate-then-bulkCreate-derived-downstream.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productCreate.product.id"
            }
          }
        }
      }
    ]
  }
}
