            "path": "$.bulkOperation.id",
            "matcher": "shopify-gid:BulkOperation",
            "reason": "BulkOperation IDs are shop-generated in Shopify and synthetic in the local proxy."
          }
        ]
      },
      {
        "name": "read-after-nested-product-variants-root-count",
        "capturePath": "$.variantRun.terminalOperation",
        "proxyPath": "$.data.bulkOperation",
        "proxyRequest": {
          "apiVersion": "2026-04",
          "documentPath": "config/parity-requests/bulk-operations/bulk-operation-by-id-parity.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "run-nested-product-variants-payload",
              "path": "$.data.bulkOperationRunQuery.bulkOperation.id"
            }
          }
        },
        "expectedDifferences": [
          {
            "path": "$.completedAt",
            "matcher": "iso-timestamp",
            "reason": "The local proxy completes the synthetic export immediately with its own deterministic clock."
          },
          {
            "path": "$.createdAt",
            "matcher": "iso-timestamp",
            "reason": "The local proxy stages a new synthetic BulkOperation instead of reusing Shopify's captured timestamp."
          },
          {
            "path": "$.fileSize",
            "matcher": "non-empty-string",
            "reason": "Shopify reports the stored artifact size while the proxy reports the byte length of its generated local JSONL."
          },
          {
            "path": "$.id",
            "matcher": "shopify-gid:BulkOperation",
            "reason": "BulkOperation IDs are shop-generated in Shopify and synthetic in the local proxy."
          },
          {
            "path": "$.url",
            "matcher": "non-empty-string",
            "reason": "Shopify returns a signed storage URL while the proxy serves an in-memory local result URL."
          }
        ]
      },
      {
        "name": "nested-product-variants-jsonl-artifact-child-rows",
        "capturePath": "$.variantRun.result.body",
        "proxyPath": "$.body",
        "proxyHttpRequest": {
          "method": "GET",
          "path": {
            "fromProxyResponse": "read-after-nested-product-variants-root-count",
            "path": "$.data.bulkOperation.url"
          }
        },
        "preserveProxyState": true,
        "jsonlRecords": true,
        "selectedPaths": [
          "$[*].id",
          "$[*].sku",
          "$[*].alt",
          "$[*].mediaContentType",
          "$[*].namespace",
          "$[*].key",
          "$[*].value",
          "$[*].__parentId"
        ],
        "expectedDifferences": [
          {
            "path": "$[0].id",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "Shopify and the proxy allocate different product variant ids."
          },
          {
            "path": "$[1].id",
            "matcher": "shopify-gid:MediaImage",
            "reason": "Shopify and the proxy allocate different media ids."
          },
          {
            "path": "$[1].__parentId",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "Child JSONL rows link to the locally allocated product variant id."
          },
          {
            "path": "$[2].id",
            "matcher": "shopify-gid:Metafield",
            "reason": "Shopify and the proxy allocate different metafield ids."
          },
          {
            "path": "$[2].__parentId",
            "matcher": "shopify-gid:ProductVariant",
            "reason": "Child JSONL rows link to the locally allocated product variant id."
          }
        ]
      },
      {
        "name": "completed-status-created-after-filter",
        "capturePath": "$.filters.completedAfter.response.data.bulkOperations",
        "proxyPath": "$.data.bulkOperations",
        "proxyRequest": {
          "apiVersion": "2026-04",
          "documentPath": "config/parity-requests/bulk-operations/bulk-operations-completed-after-filter.graphql"
        },
        "expectedDifferences": [
          {
            "path": "$.nodes[0].createdAt",
            "matcher": "iso-timestamp",
            "reason": "The captured and proxy BulkOperation jobs are created at different timestamps."
          },
          {
            "path": "$.nodes[0].id",
            "matcher": "shopify-gid:BulkOperation",
            "reason": "BulkOperation IDs are shop-generated in Shopify and synthetic in the local proxy."
          }
        ]
      },
      {
        "name": "created-before-filter-empty",
        "capturePath": "$.filters.createdBefore.response.data.bulkOperations",
