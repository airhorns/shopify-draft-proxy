          "variablesCapturePath": "$.autoCreateOne.request.variables",
          "apiVersion": "2026-04"
        },
        "expectedDifferences": [
          {
            "path": "$.id",
            "matcher": "shopify-gid:Metaobject",
            "reason": "The local proxy stages a synthetic metaobject ID while Shopify returns the captured live-store ID."
          },
          {
            "path": "$.handle",
            "matcher": "regex:^auto-handle-1778241496658-[a-z0-9]{8}$",
            "reason": "Shopify and the proxy both generate Core-shaped random handle suffixes; the concrete random value is volatile."
          },
          {
            "path": "$.displayName",
            "matcher": "regex:^Auto Handle 1778241496658 #[A-Z0-9]{8}$",
            "reason": "Display-name fallback includes the generated random code, so parity validates the Core display-name shape instead of the concrete volatile code."
          }
        ]
