{
  "scenarioId": "online-store/article-create-update-blog-not-found",
  "operationNames": ["blogCreate", "articleCreate", "articleUpdate", "article"],
  "scenarioStatus": "captured",
  "assertionKinds": ["user-errors-parity", "validation-guardrail", "read-after-write", "side-effect-boundary"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/online-store/article-create-update-blog-not-found.json"
