  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/online_store_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/online-store/online-store-article-update-validation-blog-create.graphql",
    "variablesCapturePath": "$.interactions[0].request.variables"
