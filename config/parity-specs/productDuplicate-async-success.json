{
  "scenarioId": "product-duplicate-async-success",
  "operationNames": ["productDuplicate", "productOperation"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity", "downstream-read-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/product-duplicate-async-success.json"
  ],
  "proxyRequest": {
    "documentPath": "config/parity-requests/productDuplicate-async.graphql",
    "variablesCapturePath": "$.mutation.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Captured async productDuplicate success on a disposable product. Shopify returns the mutation operation in CREATED status with null newProduct, then productOperation(id:) resolves the ProductDuplicateOperation as COMPLETE with the duplicated product.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "mutation-data",
        "capturePath": "$.mutation.response.data",
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productDuplicate.productDuplicateOperation.id",
            "matcher": "shopify-gid:ProductDuplicateOperation",
            "reason": "ProductDuplicateOperation IDs are allocated independently by Shopify and the local staging identity registry."
          }
        ]
      },
      {
        "name": "operation-read-data",
        "capturePath": "$.operationRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/productDuplicate-operation-read.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.productDuplicate.productDuplicateOperation.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.productOperation.id",
            "matcher": "shopify-gid:ProductDuplicateOperation",
            "reason": "The downstream proxy read uses the stable local ProductDuplicateOperation GID generated by the staged async productDuplicate response."
          },
          {
            "path": "$.productOperation.newProduct.id",
            "matcher": "shopify-gid:Product",
            "reason": "Duplicated product IDs are allocated independently by Shopify and the local staging identity registry."
          }
        ]
      },
      {
        "name": "downstream-product-read-data",
        "capturePath": "$.downstreamRead.response.data",
        "proxyRequest": {
          "documentPath": "config/parity-requests/productDuplicate-async-product-read.graphql",
          "variables": {
            "id": {
              "fromProxyResponse": "operation-read-data",
              "path": "$.data.productOperation.newProduct.id"
            }
          }
        },
        "proxyPath": "$.data",
        "expectedDifferences": [
          {
            "path": "$.product.id",
            "matcher": "shopify-gid:Product",
            "reason": "The downstream proxy product read uses the stable local product GID generated by the staged async duplicate."
          }
        ]
      }
    ]
  }
}
