{
  "scenarioId": "saved-search-delete-shop-payload",
  "operationNames": ["savedSearchCreate", "savedSearchDelete"],
  "scenarioStatus": "captured",
  "assertionKinds": ["payload-shape", "user-errors-parity"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/saved-searches/saved-search-delete-shop-payload.json"
  ],
  "runtimeTestFiles": ["gleam/test/shopify_draft_proxy/proxy/draft_proxy_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/saved-searches/saved-search-local-staging-create.graphql",
    "variablesCapturePath": "$.savedSearchCreate.variables",
    "apiVersion": "2025-01"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "HAR-716 live evidence that savedSearchDelete includes a non-null shop payload on success and missing-id userError branches. The proxy stages create/delete locally; deletedSavedSearchId and shop.id are expected to use deterministic proxy-local GIDs.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "success-delete payload",
        "capturePath": "$.savedSearchDelete.payload.data.savedSearchDelete",
        "proxyPath": "$.data.savedSearchDelete",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-delete-shop-payload-delete.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.savedSearchCreate.savedSearch.id"
              }
            }
          },
          "apiVersion": "2025-01"
        },
        "expectedDifferences": [
          {
            "path": "$.deletedSavedSearchId",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "The proxy deletes its deterministic local SavedSearch id while Shopify deleted the live store id."
          },
          {
            "path": "$.shop.id",
            "matcher": "shopify-gid:Shop",
            "reason": "The proxy emits its deterministic current Shop id while Shopify returned the live store Shop id."
          }
        ]
      },
      {
        "name": "missing-id userError payload",
        "capturePath": "$.missingSavedSearchDelete.payload.data.savedSearchDelete",
        "proxyPath": "$.data.savedSearchDelete",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-delete-shop-payload-delete.graphql",
          "variables": {
            "input": {
              "id": "gid://shopify/SavedSearch/0"
            }
          },
          "apiVersion": "2025-01"
        },
        "expectedDifferences": [
          {
            "path": "$.shop.id",
            "matcher": "shopify-gid:Shop",
            "reason": "The proxy emits its deterministic current Shop id while Shopify returned the live store Shop id."
          }
        ]
      }
    ]
  }
}
