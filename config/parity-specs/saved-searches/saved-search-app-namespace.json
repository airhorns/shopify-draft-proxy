{
  "scenarioId": "saved-search-app-namespace",
  "operationNames": ["savedSearchCreate", "savedSearchUpdate", "savedSearchDelete", "productSavedSearches"],
  "scenarioStatus": "captured",
  "assertionKinds": [
    "payload-shape",
    "query-grammar-parity",
    "downstream-read-parity",
    "runtime-staging",
    "no-upstream-passthrough"
  ],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/saved-searches/saved-search-app-namespace.json"
  ],
  "runtimeTestFiles": ["test/shopify_draft_proxy/proxy/draft_proxy_test.gleam"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/saved-searches/saved-search-local-staging-create.graphql",
    "variablesCapturePath": "$.savedSearchCreateAppNamespace.variables",
    "apiVersion": "2025-01",
    "headers": {
      "x-shopify-draft-proxy-api-client-id": "347082227713"
    }
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Live Shopify evidence for SavedSearch query-input app namespace resolution. Shopify resolves bare metafields.$app.<key> query tokens to metafields.app--<api_client_id>.<key> before creating or updating the SavedSearch record. Downstream productSavedSearches currently escapes the hyphens in the stored query string, so parity keeps that one string as an expected difference while strictly comparing searchTerms and filters.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "saved-search-app-namespace-create-payload",
        "capturePath": "$.savedSearchCreateAppNamespace.payload.data.savedSearchCreate",
        "proxyPath": "$.data.savedSearchCreate",
        "upstreamCapturePath": null,
        "expectedDifferences": [
          {
            "path": "$.savedSearch.id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "The proxy creates a deterministic local SavedSearch id while Shopify returned a live store id."
          },
          {
            "path": "$.savedSearch.legacyResourceId",
            "matcher": "non-empty-string",
            "reason": "The proxy derives the legacy resource id from its deterministic local SavedSearch id while Shopify returned the live store legacy id."
          }
        ]
      },
      {
        "name": "saved-search-app-namespace-read-after-create",
        "capturePath": "$.productSavedSearchesAfterCreate.payload.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-app-namespace-read.graphql",
          "variablesCapturePath": "$.productSavedSearchesAfterCreate.variables",
          "apiVersion": "2025-01",
          "headers": {
            "x-shopify-draft-proxy-api-client-id": "347082227713"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.productSavedSearches.nodes[0].id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "The downstream read returns the deterministic local SavedSearch id instead of Shopify's live id."
          },
          {
            "path": "$.productSavedSearches.nodes[0].query",
            "matcher": "exact-string:metafields.app--347082227713.tier:gold",
            "reason": "Shopify downstream SavedSearch.query escaped hyphens in app--<api_client_id>; the proxy currently stores the unescaped resolved namespace while matching filters/searchTerms."
          }
        ]
      },
      {
        "name": "saved-search-app-namespace-update-payload",
        "capturePath": "$.savedSearchUpdateAppNamespace.payload.data.savedSearchUpdate",
        "proxyPath": "$.data.savedSearchUpdate",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-app-namespace-update.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.savedSearchCreate.savedSearch.id"
              },
              "query": {
                "fromCapturePath": "$.savedSearchUpdateAppNamespace.variables.input.query"
              }
            }
          },
          "apiVersion": "2025-01",
          "headers": {
            "x-shopify-draft-proxy-api-client-id": "347082227713"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.savedSearch.id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "The proxy updates its deterministic local SavedSearch id while Shopify returned the live store id."
          },
          {
            "path": "$.savedSearch.legacyResourceId",
            "matcher": "non-empty-string",
            "reason": "The proxy derives the legacy resource id from its deterministic local SavedSearch id while Shopify returned the live store legacy id."
          }
        ]
      },
      {
        "name": "saved-search-app-namespace-read-after-update",
        "capturePath": "$.productSavedSearchesAfterUpdate.payload.data",
        "proxyPath": "$.data",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-app-namespace-read.graphql",
          "variablesCapturePath": "$.productSavedSearchesAfterUpdate.variables",
          "apiVersion": "2025-01",
          "headers": {
            "x-shopify-draft-proxy-api-client-id": "347082227713"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.productSavedSearches.nodes[0].id",
            "matcher": "shopify-gid:SavedSearch",
            "reason": "The downstream read returns the deterministic local SavedSearch id instead of Shopify's live id."
          },
          {
            "path": "$.productSavedSearches.nodes[0].query",
            "matcher": "exact-string:metafields.app--347082227713.vip:true",
            "reason": "Shopify downstream SavedSearch.query escaped hyphens in app--<api_client_id>; the proxy currently stores the unescaped resolved namespace while matching filters/searchTerms."
          }
        ]
      },
      {
        "name": "saved-search-app-namespace-cleanup-delete",
        "capturePath": "$.cleanupDelete.payload.data.savedSearchDelete",
        "proxyPath": "$.data.savedSearchDelete",
        "upstreamCapturePath": null,
        "proxyRequest": {
          "documentPath": "config/parity-requests/saved-searches/saved-search-query-grammar-delete.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.savedSearchCreate.savedSearch.id"
              }
            }
          },
          "apiVersion": "2025-01",
          "headers": {
            "x-shopify-draft-proxy-api-client-id": "347082227713"
          }
        },
        "expectedDifferences": [
          {
            "path": "$.deletedSavedSearchId",
