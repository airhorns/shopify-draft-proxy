          "apiVersion": "2026-04"
        },
        "expectedDifferences": [
          {
            "path": "$.order.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy creates the setup order locally and returns its generated Order GID."
          },
          {
            "path": "$.order.customer.id",
            "matcher": "shopify-gid:Customer",
            "reason": "The proxy links the locally staged customer generated by setup-removable-customer."
          }
        ]
      },
      {
        "name": "happy-remove",
        "capturePath": "$.cases.happyRemove.response.body.data.orderCustomerRemove",
        "proxyPath": "$.data.orderCustomerRemove",
        "proxyRequest": {
