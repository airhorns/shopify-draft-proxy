      {
        "name": "happy-set",
        "capturePath": "$.cases.happySet.response.body.data.orderCustomerSet",
        "proxyPath": "$.data.orderCustomerSet",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/orderCustomerSet-error-paths.graphql",
          "variables": {
            "orderId": {
              "fromProxyResponse": "setup-happy-order",
              "path": "$.data.orderCreate.order.id"
