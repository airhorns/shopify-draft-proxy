      {
        "name": "setup-customer",
        "capturePath": "$.expected.customerCreate.data.customerCreate.userErrors",
        "proxyPath": "$.data.customerCreate.userErrors"
      },
      {
        "name": "setup-order",
        "capturePath": "$.expected.setupOrderCreate.data.orderCreate.userErrors",
        "proxyPath": "$.data.orderCreate.userErrors",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/orderCancel-state-transitions-order-create.graphql",
          "variablesCapturePath": "$.setup.orderCreate.variables",
          "apiVersion": "2026-04"
        }
      },
      {
        "name": "happy-set",
        "capturePath": "$.expected.happySet.data.orderCustomerSet",
        "proxyPath": "$.data.orderCustomerSet",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/orderCustomerSet-error-paths.graphql",
          "variables": {
            "orderId": {
              "fromProxyResponse": "setup-order",
              "path": "$.data.orderCreate.order.id"
            },
            "customerId": {
              "fromPrimaryProxyPath": "$.data.customerCreate.customer.id"
            }
          },
          "apiVersion": "2026-04"
        },
        "expectedDifferences": [
          {
            "path": "$.order.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy creates the setup order locally and returns its generated Order GID."
          },
          {
            "path": "$.order.customer.id",
            "matcher": "shopify-gid:Customer",
            "reason": "The proxy links the locally staged customer generated by the primary setup request."
          }
        ]
      },
      {
        "name": "happy-remove",
        "capturePath": "$.expected.happyRemove.data.orderCustomerRemove",
        "proxyPath": "$.data.orderCustomerRemove",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/orderCustomerRemove-error-paths.graphql",
          "variables": {
            "orderId": {
              "fromProxyResponse": "setup-order",
              "path": "$.data.orderCreate.order.id"
            }
          },
          "apiVersion": "2026-04"
        },
        "expectedDifferences": [
          {
            "path": "$.order.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy removes the customer from the locally generated setup order."
          }
        ]
      },
