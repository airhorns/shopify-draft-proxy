  "assertionKinds": ["payload-shape", "selected-fields", "downstream-read-parity"],
  "runtimeTestFiles": ["tests/graphql_routes/orders.rs"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/orders/draft-order-create-payment-terms.json"
