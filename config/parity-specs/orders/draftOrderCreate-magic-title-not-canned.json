  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "magic-title-create-user-errors",
        "capturePath": "$.create.response.data.draftOrderCreate.userErrors",
