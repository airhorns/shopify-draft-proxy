{
  "scenarioId": "order-payment-mandate-local-staging",
  "operationNames": ["orderCreate", "orderCreateMandatePayment"],
  "scenarioStatus": "captured",
  "assertionKinds": ["runtime-staging", "downstream-read-parity", "idempotency"],
  "liveCaptureFiles": [
    "fixtures/conformance/local-runtime/2026-04/orders/order-payment-transaction-local-staging.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/orders.rs"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/orders/order-payment-create-local-staging.graphql",
    "variablesCapturePath": "$.mandateFlow.create.variables"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "mandate-payment-stages-paid-order",
        "capturePath": "$.mandateFlow.expected.mandate",
        "proxyPath": "$",
        "expectedDifferences": [
          {
            "path": "$.data.orderCreateMandatePayment.job.id",
            "matcher": "shopify-gid:Job",
            "reason": "Mandate job IDs are allocated by the proxy session and are volatile; parity keeps status, structure, and non-id fields strict."
          },
          {
            "path": "$.data.orderCreateMandatePayment.order.transactions[0].id",
            "matcher": "shopify-gid:OrderTransaction",
            "reason": "Mandate transaction IDs are derived from staged order/payment state and are volatile across sessions."
          }
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/order-payment-mandate-local-staging.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
            },
            "mandateId": "gid://shopify/PaymentMandate/har-397",
            "idempotencyKey": "har-353-idempotent-payment",
            "amount": {
              "amount": "25.00",
              "currencyCode": "CAD"
            }
          }
        }
      },
      {
        "name": "mandate-payment-repeat-is-idempotent",
        "capturePath": "$.mandateFlow.expected.repeatMandate",
        "proxyPath": "$",
        "expectedDifferences": [
          {
            "path": "$.data.orderCreateMandatePayment.job.id",
            "matcher": "shopify-gid:Job",
            "reason": "The repeat returns the session-allocated mandate job ID; exact ID values are volatile."
          },
          {
            "path": "$.data.orderCreateMandatePayment.order.transactions[0].id",
            "matcher": "shopify-gid:OrderTransaction",
            "reason": "The repeat returns the idempotently staged mandate transaction ID; exact ID values are volatile."
          }
        ],
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/order-payment-mandate-local-staging.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
            },
            "mandateId": "gid://shopify/PaymentMandate/har-397",
            "idempotencyKey": "har-353-idempotent-payment",
            "amount": {
              "amount": "25.00",
              "currencyCode": "CAD"
            }
          }
        }
      }
    ]
  },
  "notes": "Executable sibling scenario for the successful orderCreateMandatePayment branch. It replays a pending synthetic order, stages a mandate payment locally with Shopify's composite order/idempotency paymentReferenceId, and verifies the repeat call with the same idempotency key does not create duplicate payment transactions."
}
