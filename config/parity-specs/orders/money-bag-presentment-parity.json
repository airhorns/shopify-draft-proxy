{
  "scenarioId": "money-bag-presentment-parity",
  "operationNames": ["orderCreate", "orderMarkAsPaid", "refundCreate", "orderEditBegin", "orderEditCommit"],
  "scenarioStatus": "captured",
  "assertionKinds": ["money-math-parity", "payload-shape", "state-validation"],
  "liveCaptureFiles": [
    "fixtures/conformance/harry-test-heelo.myshopify.com/2025-01/orders/money-bag-presentment-parity.json"
  ],
  "runtimeTestFiles": ["tests/graphql_routes/orders.rs"],
  "proxyRequest": {
    "documentPath": "config/parity-requests/orders/money-bag-presentment-single-create.graphql",
    "variablesCapturePath": "$.orderCreate.variables",
    "apiVersion": "2025-01"
  },
  "comparisonMode": "captured-vs-proxy-request",
  "notes": "Live 2025-01 Shopify Admin GraphQL capture for MoneyBag presentment propagation through orderCreate, orderEditBegin/orderEditCommit, orderMarkAsPaid, and refundCreate on one disposable multi-currency order. The edit branch is captured before payment/refund because Shopify rejects edit begin on the paid/refunded order. Shopify applies a store FX rate when settling mark-as-paid and refund shopMoney amounts; the proxy preserves the captured presentment currency/amount strictly and treats only those opaque shopMoney amount conversions as expected differences. This replaces the retired proxy/local-runtime fixture; replay uses public GraphQL requests only and does not seed private proxy state. Evidence trail: registered capture script scripts/capture-money-bag-presentment-conformance.ts writes the listed fixture and request files through capture-index entry money-bag-presentment; tests/graphql_routes/orders.rs keeps the local money-helper projection path executable.",
  "comparison": {
    "mode": "strict-json",
    "expectedDifferences": [],
    "targets": [
      {
        "name": "order-create",
        "capturePath": "$.orderCreate.response.payload.data.orderCreate",
        "proxyPath": "$.data.orderCreate",
        "expectedDifferences": [
          {
            "path": "$.order.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy generates a synthetic local order ID."
          }
        ]
      },
      {
        "name": "order-edit-begin",
        "capturePath": "$.orderEditBegin.response.payload.data.orderEditBegin",
        "proxyPath": "$.data.orderEditBegin",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/money-bag-presentment-order-edit-begin.graphql",
          "variables": {
            "id": {
              "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
            }
          },
          "apiVersion": "2025-01"
        },
        "expectedDifferences": [
          {
            "path": "$.calculatedOrder.id",
            "matcher": "shopify-gid:CalculatedOrder",
            "reason": "The proxy generates a synthetic local calculated order ID."
          },
          {
            "path": "$.calculatedOrder.originalOrder.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy returns the synthetic order ID from the primary local orderCreate request."
          }
        ]
      },
      {
        "name": "order-edit-commit",
        "capturePath": "$.orderEditCommit.response.payload.data.orderEditCommit",
        "proxyPath": "$.data.orderEditCommit",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/money-bag-presentment-order-edit-commit.graphql",
          "variables": {
            "id": {
              "fromPreviousProxyPath": "$.data.orderEditBegin.calculatedOrder.id"
            }
          },
          "apiVersion": "2025-01"
        }
      },
      {
        "name": "mark-as-paid",
        "capturePath": "$.markAsPaid.response.payload.data.orderMarkAsPaid",
        "proxyPath": "$.data.orderMarkAsPaid",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/money-bag-presentment-mark-as-paid.graphql",
          "variables": {
            "input": {
              "id": {
                "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
              }
            }
          },
          "apiVersion": "2025-01"
        },
        "expectedDifferences": [
          {
            "path": "$.order.id",
            "matcher": "shopify-gid:Order",
            "reason": "The proxy returns the synthetic order ID from the primary local orderCreate request."
          },
          {
            "path": "$.order.transactions[0].id",
            "matcher": "shopify-gid:OrderTransaction",
            "reason": "The proxy generates a synthetic local payment transaction ID."
          },
          {
            "path": "$.order.transactions[0].amountSet.shopMoney.amount",
            "matcher": "regex:^\\d+(?:\\.\\d+)?$",
            "reason": "Shopify applies a live store FX settlement rate for mark-as-paid shopMoney that is not present in the orderCreate input; the proxy derives a deterministic shop amount from staged money-bag state while comparing presentment money strictly."
          }
        ]
      },
      {
        "name": "refund",
        "capturePath": "$.refund.response.payload.data.refundCreate",
        "proxyPath": "$.data.refundCreate",
        "proxyRequest": {
          "documentPath": "config/parity-requests/orders/money-bag-presentment-refund.graphql",
          "variables": {
            "input": {
              "orderId": {
                "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
              },
              "currency": "USD",
              "allowOverRefunding": true,
              "transactions": [
                {
                  "amount": "5.00",
                  "gateway": "manual",
                  "kind": "REFUND",
                  "orderId": {
                    "fromPrimaryProxyPath": "$.data.orderCreate.order.id"
                  },
                  "parentId": {
                    "fromProxyResponse": "mark-as-paid",
                    "path": "$.data.orderMarkAsPaid.order.transactions[0].id"
                  }
                }
              ]
            }
          },
          "apiVersion": "2025-01"
        },
        "expectedDifferences": [
          {
            "path": "$.order.totalRefundedSet.shopMoney.amount",
            "matcher": "regex:^\\d+(?:\\.\\d+)?$",
            "reason": "Shopify applies a live store FX settlement rate for refund shopMoney that is not present in the orderCreate input; the proxy derives a deterministic shop amount from the staged parent transaction while comparing presentment money strictly."
          },
          {
            "path": "$.refund.totalRefundedSet.shopMoney.amount",
            "matcher": "regex:^\\d+(?:\\.\\d+)?$",
            "reason": "Shopify applies a live store FX settlement rate for refund shopMoney that is not present in the orderCreate input; the proxy derives a deterministic shop amount from the staged parent transaction while comparing presentment money strictly."
          }
        ]
      }
    ]
  }
}
