{
  "source": "local-runtime-parity-harness",
  "apiVersion": "2025-01",
  "scenarioId": "inventory-quantity-updated-at-and-after-change-local-runtime",
  "notes": "Executable local-runtime parity for inventorySetQuantities and inventoryMoveQuantities fields that were previously hardcoded null in the draft proxy. The flow stages an available set, reads per-quantity updatedAt values, moves available to damaged, then reads again without runtime Shopify writes. Existing live captures for these roots predate this local staging fidelity and record null quantityAfterChange, so this fixture is a proxy-runtime guardrail rather than edited Shopify evidence.",
  "workflow": {
    "set": {
      "variables": {
        "input": {
          "name": "available",
          "reason": "correction",
          "referenceDocumentUri": "logistics://inventory-updated-at/set",
          "ignoreCompareQuantity": true,
          "quantities": [
            {
              "inventoryItemId": "gid://shopify/InventoryItem/1401",
              "locationId": "gid://shopify/Location/106318430514",
              "quantity": 8
            }
          ]
        }
      },
      "response": {
        "payload": {
          "data": {
            "inventorySetQuantities": {
              "inventoryAdjustmentGroup": {
                "reason": "correction",
                "referenceDocumentUri": "logistics://inventory-updated-at/set",
                "changes": [
                  {
                    "name": "available",
                    "delta": 8,
                    "quantityAfterChange": 8,
                    "ledgerDocumentUri": null,
                    "location": {
                      "id": "gid://shopify/Location/106318430514",
                      "name": "Shop location"
                    }
                  },
                  {
                    "name": "on_hand",
                    "delta": 8,
                    "quantityAfterChange": 8,
                    "ledgerDocumentUri": null,
                    "location": {
                      "id": "gid://shopify/Location/106318430514",
                      "name": "Shop location"
                    }
                  }
                ]
              },
              "userErrors": []
            }
          }
        }
      }
    },
    "afterSet": {
      "variables": {
        "inventoryItemId": "gid://shopify/InventoryItem/1401"
      },
      "response": {
        "payload": {
          "data": {
            "inventoryItem": {
              "inventoryLevels": {
                "nodes": [
                  {
                    "location": {
                      "id": "gid://shopify/Location/106318430514"
                    },
                    "quantities": [
                      {
                        "name": "available",
                        "quantity": 8,
                        "updatedAt": "2024-01-01T00:00:00.000Z"
                      },
                      {
                        "name": "on_hand",
                        "quantity": 8,
                        "updatedAt": "2024-01-01T00:00:00.000Z"
                      },
                      {
                        "name": "damaged",
                        "quantity": 0,
                        "updatedAt": null
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    "move": {
      "variables": {
        "input": {
          "reason": "correction",
          "referenceDocumentUri": "logistics://inventory-updated-at/move",
          "changes": [
            {
              "inventoryItemId": "gid://shopify/InventoryItem/1401",
              "quantity": 3,
              "from": {
                "locationId": "gid://shopify/Location/106318430514",
                "name": "available"
              },
              "to": {
                "locationId": "gid://shopify/Location/106318430514",
                "name": "damaged",
                "ledgerDocumentUri": "ledger://inventory-updated-at/move"
              }
            }
          ]
        }
      },
      "response": {
        "payload": {
          "data": {
            "inventoryMoveQuantities": {
              "inventoryAdjustmentGroup": {
                "reason": "correction",
                "referenceDocumentUri": "logistics://inventory-updated-at/move",
                "changes": [
                  {
                    "name": "available",
                    "delta": -3,
                    "quantityAfterChange": 5,
                    "ledgerDocumentUri": null,
                    "location": {
                      "id": "gid://shopify/Location/106318430514",
                      "name": "Shop location"
                    }
                  },
                  {
                    "name": "damaged",
                    "delta": 3,
                    "quantityAfterChange": 3,
                    "ledgerDocumentUri": "ledger://inventory-updated-at/move",
                    "location": {
                      "id": "gid://shopify/Location/106318430514",
                      "name": "Shop location"
                    }
                  }
                ]
              },
              "userErrors": []
            }
          }
        }
      }
    },
    "afterMove": {
      "variables": {
        "inventoryItemId": "gid://shopify/InventoryItem/1401"
      },
      "response": {
        "payload": {
          "data": {
            "inventoryItem": {
              "inventoryLevels": {
                "nodes": [
                  {
                    "location": {
                      "id": "gid://shopify/Location/106318430514"
                    },
                    "quantities": [
                      {
                        "name": "available",
                        "quantity": 5,
                        "updatedAt": "2024-01-01T00:00:01.000Z"
                      },
                      {
                        "name": "on_hand",
                        "quantity": 8,
                        "updatedAt": "2024-01-01T00:00:00.000Z"
                      },
                      {
                        "name": "damaged",
                        "quantity": 3,
                        "updatedAt": "2024-01-01T00:00:01.000Z"
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "runtimeEvidence": [
    "inventorySetQuantities returns quantityAfterChange for available and mirrored on_hand changes.",
    "inventoryLevel.quantities exposes non-null updatedAt only for names touched by set.",
    "inventoryMoveQuantities returns quantityAfterChange for source and destination changes.",
    "inventoryMoveQuantities updates moved quantity updatedAt values while preserving untouched on_hand updatedAt."
  ],
  "upstreamCalls": []
}
