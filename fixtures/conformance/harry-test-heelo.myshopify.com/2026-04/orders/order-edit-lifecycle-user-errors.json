  "cases": [
    {
      "name": "begin-not-found",
      "query": "mutation OrderEditLifecycleBeginNotFound($id: ID!) {\n    orderEditBegin(id: $id) {\n      calculatedOrder {\n        id\n      }\n      userErrors {\n        field\n        message\n      }\n    }\n  }",
      "variables": {
        "id": "gid://shopify/Order/0"
      },
      "response": {
        "status": 200,
        "payload": {
          "data": {
            "orderEditBegin": {
              "calculatedOrder": null,
              "userErrors": [
                {
                  "field": ["id"],
                  "message": "The order does not exist."
                }
              ]
            }
          },
          "extensions": {
            "cost": {
              "requestedQueryCost": 10,
              "actualQueryCost": 10,
              "throttleStatus": {
                "maximumAvailable": 2000,
                "currentlyAvailable": 1990,
                "restoreRate": 100
              }
            }
          }
        }
      }
    },
